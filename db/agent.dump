DROP TABLE IF EXISTS `context_files`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `context_files` (
  `id` varchar(36) NOT NULL,
  `workspace_id` varchar(36) NOT NULL DEFAULT '00000000-0000-0000-0000-000000000001',
  `scope` enum('global','user') NOT NULL,
  `user_id` varchar(255) DEFAULT NULL,
  `path` varchar(255) NOT NULL,
  `content` text NOT NULL,
  `updated_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uq_context_file` (`workspace_id`,`scope`,`user_id`,`path`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

