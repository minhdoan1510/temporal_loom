INSERT INTO `routines` VALUES ('17626e29-adfd-4d4e-8f9b-3b4d19b0b143','00000000-0000-0000-0000-000000000001','Tổng hợp cs ticket theo tháng','[autonomous]\nHãy đọc hết tất cả các cs ticket bằng jql này labels = auto_resolved sau đó hãy tổng hợp thành 1 bản report nguyên nhân cs ticket\n- Nguyên nhân\n- Hướng xử lý\n\nSau đó gửi email báo cáo về địa chỉ email minhdc3@vng.com.vn khangldh2@vng.com.vn duylvh@vng.com.vn','routine',0,'0 9 14 6 *','Asia/Ho_Chi_Minh','routine@00000000-0000-0000-0000-000000000001@17626e29-adfd-4d4e-8f9b-3b4d19b0b143',NULL,NULL,'2026-06-16 07:29:24','2026-06-17 08:20:29',NULL);
INSERT INTO `routines` VALUES ('358f9e32-5487-4d1d-90d9-31cc0d82d113','00000000-0000-0000-0000-000000000001','Tổng hợp báo cáo CS theo tháng','Tổng hợp báo cáo CS ticket tháng này theo labels = auto_resolved và gửi report báo cáo qua email\n\nNguyên nhân\nHướng xử lý\nĐề xuất cải tiến\nVà build thành chart theo nguyên nhân đi\n\n','routine',0,'0 * * * *','Asia/Ho_Chi_Minh','routine@00000000-0000-0000-0000-000000000001@358f9e32-5487-4d1d-90d9-31cc0d82d113',NULL,NULL,'2026-06-16 11:38:47','2026-06-17 08:20:21',NULL);
INSERT INTO `routines` VALUES ('36a251d6-ba47-4416-b846-8452549298fb','00000000-0000-0000-0000-000000000001','Tổng hợp báo cáo CS ticket theo tuần','Tổng hợp báo cáo CS ticket tuần vừa qua theo labels = auto_resolved và gửi report báo cáo qua email\n- Nguyên nhân\n- Hướng xử lý\n- Đề xuất cải tiến\n\nemail: minhdc3@vng.com.vn','routine',0,'0 9 * * 0','Asia/Ho_Chi_Minh','routine@00000000-0000-0000-0000-000000000001@36a251d6-ba47-4416-b846-8452549298fb',NULL,NULL,'2026-06-16 11:00:06','2026-06-17 08:20:26',NULL);
INSERT INTO `routines` VALUES ('7bfd2401-e531-4915-b6b5-71677532a3f9','00000000-0000-0000-0000-000000000001','Xử lý cs ticket mỗi ngày ','[autonomous]\nHãy đọc hết tất cả các cs ticket bằng jql này.labels = auto_resolved sau đó hãy xử lý lần lượt từng ticket','routine',0,'45 17 16 6 *','Asia/Ho_Chi_Minh','routine@00000000-0000-0000-0000-000000000001@7bfd2401-e531-4915-b6b5-71677532a3f9',NULL,NULL,'2026-06-16 03:44:31','2026-06-17 08:20:30',NULL);
