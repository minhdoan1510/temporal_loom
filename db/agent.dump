LOCK TABLES `mcp_functions` WRITE;
/*!40000 ALTER TABLE `mcp_functions` DISABLE KEYS */;
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','cashloan_api','get_customer_loans','Get all loan applications for a specific customer by their ZaloPay user ID. Returns a summary list of all loan applications including status, amount, and timestamps.','{\"type\": \"object\", \"required\": [\"user_id\"], \"properties\": {\"user_id\": {\"type\": \"string\", \"description\": \"The ZaloPay user ID to look up loans for\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:20:52','2026-05-20 17:20:52');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','cashloan_api','get_loan_detail','Get detailed information about a specific loan application by its loan application ID. Returns status, amount, term, partner details, approval info, and all timestamps.','{\"type\": \"object\", \"required\": [\"loan_application_id\"], \"properties\": {\"loan_application_id\": {\"type\": \"string\", \"description\": \"The loan application ID to look up\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:20:52','2026-05-20 17:20:52');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','datawarehouse','query_sql','Run a read-only SQL query against the lending data warehouse and return the result set. Use standard SQL SELECT syntax. Provide optional `schema` hints (table/column descriptions) to ground the results. Returns rows as a Markdown table.','{\"type\": \"object\", \"required\": [\"sql\"], \"properties\": {\"sql\": {\"type\": \"string\", \"description\": \"The SQL SELECT query to run against the data warehouse\"}, \"schema\": {\"type\": \"string\", \"description\": \"Optional table/column descriptions or context to ground the result\"}}, \"additionalProperties\": false}',1,'2026-06-16 21:34:45','2026-06-16 21:34:45');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','jira','comment_jira','Add a comment to a JIRA ticket. Use this to post analysis results, resolution steps, or status updates on tickets.','{\"type\": \"object\", \"required\": [\"ticket_id\", \"comment\"], \"properties\": {\"comment\": {\"type\": \"string\", \"description\": \"The comment text to add to the ticket\"}, \"ticket_id\": {\"type\": \"string\", \"description\": \"The JIRA ticket key (e.g., \\\"LENDING-123\\\")\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:19:56','2026-05-20 17:19:56');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','jira','get_jira_comments','Get all comments on a JIRA ticket. Use this to see the conversation history and previous analysis on a ticket.','{\"type\": \"object\", \"required\": [\"ticket_id\"], \"properties\": {\"ticket_id\": {\"type\": \"string\", \"description\": \"The JIRA ticket key (e.g., \\\"LENDING-123\\\")\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:19:56','2026-05-20 17:19:56');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','jira','get_jira_tickets_by_jql','Search for a list of JIRA CS tickets using a JQL query. Returns a concise list with only the ticket key and title (summary) for each match. Use this to discover which tickets to work on before reading their full details.','{\"type\": \"object\", \"required\": [\"jql\"], \"properties\": {\"jql\": {\"type\": \"string\", \"description\": \"The JQL query to filter CS tickets (e.g., \\\"project = LENDING AND status = Open ORDER BY created DESC\\\")\"}, \"max_results\": {\"type\": \"integer\", \"description\": \"Maximum number of tickets to return (default: 50)\"}}, \"additionalProperties\": false}',1,'2026-06-15 19:37:06','2026-06-15 19:37:06');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','jira','mark_done_cs_ticket','Close a CS ticket by driving it through the Acknowledge → Assigned → In Progress → Resolved workflow, attaching root cause + resolution metadata on the final step, and tagging the ticket with the \"auto_resolved\" label.\n\nCRITICAL: Call this tool ONLY after the underlying issue described in the ticket has actually been investigated and handled (root cause identified, customer informed if needed, fix or explanation delivered). Do NOT call this tool to:\n- Tidy up old or stale tickets without resolving them.\n- Skip past tickets you don\'t understand.\n- Bulk-close tickets without per-ticket verification.\n\nCalling this on an unresolved ticket leaves the customer issue untouched while marking it Done in Jira — a hard incident. If you are not certain the ticket\'s underlying work is complete, do not call this tool; ask the user or leave the ticket open.\n\nThe tool is idempotent if the ticket is already in Resolved state.','{\"type\": \"object\", \"required\": [\"issue_key\", \"root_cause_type\"], \"properties\": {\"issue_key\": {\"type\": \"string\", \"description\": \"The JIRA ticket key (e.g., \\\"LENDING-123\\\")\"}, \"root_cause_type\": {\"type\": \"string\", \"description\": \"Root cause classification. Accepts an alias (\'communication\' or \'external_factors\') or a raw customfield_13621 option ID.\"}}, \"additionalProperties\": false}',1,'2026-06-04 10:10:37','2026-06-04 10:10:37');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','jira','read_jira_ticket','Read detailed information from a JIRA ticket including summary, description, status, priority, assignee, labels, and components.','{\"type\": \"object\", \"required\": [\"ticket_id\"], \"properties\": {\"ticket_id\": {\"type\": \"string\", \"description\": \"The JIRA ticket key (e.g., \\\"LENDING-123\\\")\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:19:56','2026-05-20 17:19:56');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','mail','send_mail','Send a transactional email via Resend. Provide one or more recipients in `to`, a `subject`, and a `body`. Set is_html=true when the body contains HTML markup.','{\"type\": \"object\", \"required\": [\"to\", \"subject\", \"body\"], \"properties\": {\"cc\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"Optional CC recipient email addresses\"}, \"to\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"Recipient email addresses (at least one required)\"}, \"bcc\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"description\": \"Optional BCC recipient email addresses\"}, \"body\": {\"type\": \"string\", \"description\": \"Email body. Plain text by default; set is_html=true to send HTML.\"}, \"from\": {\"type\": \"string\", \"description\": \"Optional sender address; defaults to the configured from_email\"}, \"is_html\": {\"type\": \"boolean\", \"description\": \"If true, body is treated as HTML; otherwise as plain text (default: false)\"}, \"subject\": {\"type\": \"string\", \"description\": \"Email subject line\"}}}',1,'2026-06-16 21:34:15','2026-06-16 21:49:55');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','opensearch','get_activity_log','Search activity-component logs scoped to a specific loan application. Use this when investigating whether a loan-submission flow to a partner failed (e.g. user reports submit/hồ sơ errors, partner integration issues). Requires loan_application_id.','{\"type\": \"object\", \"required\": [\"loan_application_id\", \"event_time\"], \"properties\": {\"event_time\": {\"type\": \"string\", \"description\": \"The center time for the search window (ISO format).\"}, \"hours_delta\": {\"type\": \"integer\", \"description\": \"Hours before and after event_time to search (default: 36)\"}, \"loan_application_id\": {\"type\": \"string\", \"description\": \"The loan application ID to search activity-component logs for\"}}, \"additionalProperties\": false}',1,'2026-05-28 17:17:59','2026-05-28 17:17:59');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','opensearch','get_api_info','Search HTTP logs for a specific API method called for a user (filters by method, component http, and user_id). Use this when the user reports incorrect or missing data displayed in the app and you know which API serves that data. Supported methods: GetActiveLoan (outstanding loan balance & due date).','{\"type\": \"object\", \"required\": [\"method\", \"user_id\", \"event_time\"], \"properties\": {\"method\": {\"type\": \"string\", \"description\": \"API method name. Supported: GetActiveLoan\"}, \"user_id\": {\"type\": \"string\", \"description\": \"The user ID (ZaloPay ID) whose API logs to fetch\"}, \"event_time\": {\"type\": \"string\", \"description\": \"The center time for the search window (ISO format).\"}, \"hours_delta\": {\"type\": \"integer\", \"description\": \"Hours before and after event_time to search (default: 36)\"}}, \"additionalProperties\": false}',1,'2026-05-28 17:17:59','2026-05-28 17:17:59');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','opensearch','get_logs_by_trace_id','Retrieve all log entries associated with a specific trace ID. Use this to follow the complete request flow across services and identify where failures occurred.','{\"type\": \"object\", \"required\": [\"trace_id\", \"event_time\"], \"properties\": {\"trace_id\": {\"type\": \"string\", \"description\": \"The trace ID to search for\"}, \"event_time\": {\"type\": \"string\", \"description\": \"The center time for the search window (ISO format).\"}, \"hours_delta\": {\"type\": \"integer\", \"description\": \"Hours before and after event_time to search (default: 36)\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:20:35','2026-05-28 17:17:59');
INSERT INTO `mcp_functions` VALUES ('00000000-0000-0000-0000-000000000001','opensearch','search_http_errors','Search for HTTP error logs related to a specific user within a time range. Use this to investigate error patterns, failed requests, and service issues for a user.','{\"type\": \"object\", \"required\": [\"user_id\", \"event_time\"], \"properties\": {\"user_id\": {\"type\": \"string\", \"description\": \"The user ID (ZaloPay ID) to search errors for\"}, \"event_time\": {\"type\": \"string\", \"description\": \"The center time for the search window (ISO format, e.g., \'2025-01-15T10:30:00\').\"}, \"hours_delta\": {\"type\": \"integer\", \"description\": \"Hours before and after event_time to search (default: 36)\"}}, \"additionalProperties\": false}',1,'2026-05-20 17:20:35','2026-05-28 17:17:59');
INSERT INTO `mcp_functions` VALUES ('606b70bb-f4f3-4677-8b32-9bfe0404dfd1','cashloan_api','get_customer_loans','Get all loan applications for a specific customer by their ZaloPay user ID. Returns a summary list of all loan applications including status, amount, and timestamps.','{\"type\": \"object\", \"required\": [\"user_id\"], \"properties\": {\"user_id\": {\"type\": \"string\", \"description\": \"The ZaloPay user ID to look up loans for\"}}, \"additionalProperties\": false}',1,'2026-06-06 15:01:04','2026-06-06 15:01:04');
INSERT INTO `mcp_functions` VALUES ('606b70bb-f4f3-4677-8b32-9bfe0404dfd1','cashloan_api','get_loan_detail','Get detailed information about a specific loan application by its loan application ID. Returns status, amount, term, partner details, approval info, and all timestamps.','{\"type\": \"object\", \"required\": [\"loan_application_id\"], \"properties\": {\"loan_application_id\": {\"type\": \"string\", \"description\": \"The loan application ID to look up\"}}, \"additionalProperties\": false}',1,'2026-06-06 15:01:04','2026-06-06 15:01:04');
/*!40000 ALTER TABLE `mcp_functions` ENABLE KEYS */;
UNLOCK TABLES;

