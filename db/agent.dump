INSERT INTO `skill_files` VALUES ('05f44ef8-69d7-40d9-b556-c6b6e8bffafa','00000000-0000-0000-0000-000000000001','0365df0b-bc26-4abc-ae31-08df5d693e6c','reference/casebook.md','# Auto-close casebook (calibration)\n\nWorked examples from a PROD audit (2026-06-08) of `labels = ai_resolve` tickets, calibrating the gates in [autoclose-gates.md](autoclose-gates.md). This is evidence, not binding logic. Bot account on PROD: `247_adm`. Auto-close (`auto_resolved` label) went live ~2026-06-04.\n\n## Contents\n- Audit headline\n- JUSTIFIED auto-closes (keep doing this)\n- RISKY auto-closes (must now be blocked)\n- \"3rd Party Issue\" ≠ external_factors\n- Mis-diagnosis patterns (KB / decode gaps)\n- Missed easy win\n- CTA altitude\n\n## Audit headline\n- Of 6 real auto-closes, **3 JUSTIFIED / 3 RISKY** — the risky ones violated gates that already existed but weren\'t enforced. Auto-close precision is the #1 live risk.\n- Human-closed `Done` comments had consistently strong diagnostics (loan ID + trace + code + stage). Weaknesses: literal error-code reading, escalate-only CTAs, KB gaps.\n- Every `3rd Party Issue` ticket still required internal work → `external_factors` would have been premature.\n\n## JUSTIFIED auto-closes (keep doing this)\n- **ISSUE-40886 / 40805 (SHB, \"tất toán app chưa cập nhật\")** — `working_as_designed`: SHB settlement syncs at contract end-date. Loan ID + status 1/FINISH/code 0. KB cited. Terminal CTA. ✅\n- **ISSUE-40636 (CAKE, \"upload image fail\")** — `partner_decision` with a **decoded** code: `-18` + log `100002 Hình selfie không đúng` + trace. Customer-actionable (\"chụp lại selfie, tạo hồ sơ mới\"). Human confirmed by closing. ✅ Strongest evidence in the set.\n\n## RISKY auto-closes (must now be blocked)\n- **ISSUE-40763 (SHB, \"vì sao hồ sơ bị huỷ?\")** — closed with \"không thoả mãn chính sách\" + \"liên hệ tổng đài SHB để kiểm tra\". Code `-23` never decoded. → violates **A1** (deflection) + **A7** (didn\'t answer \"why\") + **B3** (code undecoded).\n- **ISSUE-40780 (TNEX, \"OTP quá số lần, xin huỷ hồ sơ\")** — confirmed FINISH but refused the cancel/re-register ask; Nguyên nhân said the OTP issue \"có thể\" was transient. → violates **A2** (hedging) + **A7** (ignored the ask).\n- **ISSUE-40759 (\"Vietinbank không có trong danh sách giải ngân\")** — free-text, **template abandoned**; asserted partner=TNEX with no loan-ID linkage; no evidence, no KB. → violates **A8** + **A9**.\n\n## \"3rd Party Issue\" ≠ external_factors\nAll TNEX-400 tickets had strong evidence yet needed internal work afterward:\n- **ISSUE-38894 / 38808 / 38474** (`GetActiveLoan`/`GetOutstandingBalance` 400 / `response=null`) — dev had to **backfill missing internal data** first. Root Cause Type field = \"Human - Coding\". 38474 took 9 days (SLA breach).\n- **ISSUE-38443 / 38444** (TNEX `ConfirmRegistration` 400 on OTP, duplicates) — ZaloPay hadn\'t handled a new TNEX error code; CS manually cancelled the profile to bypass. 38444\'s evidence was weak (`response=null` + speculation).\n\nLesson: a partner 400 / `response=null` is a proximate symptom of an internal data/handler gap. Reserve `external_factors` for affirmative proof the partner owns the fix AND nothing internal is pending. Dedup sibling tickets.\n\n## Mis-diagnosis patterns (KB / decode gaps)\n- **Literal error-code reading** → wrong root cause: `-18` → CMND→CCCD identity mismatch (ISSUE-40082, Unresolved); `StepCode invalid` / `Trạng thái hợp đồng không hợp lệ` → expired signing window → re-apply (ISSUE-39962, 39989 — comments MISLEADING).\n- **Trusting the reporter\'s timestamp** → empty window → \"probably fixed, re-test\"; real events on another day + a back-nav UI bug (ISSUE-38625, Unresolved).\n- **Trusting the reporter\'s channel** → bot said push \"Noti\"; real surface was home-screen entry points + a CRM-segment exclusion miss (ISSUE-40087).\n- **KB gap on benign policy** → bot reasoned to the right hypothesis (payment UI shows only at DPD 1-5) but escalated because the rule wasn\'t in KB (ISSUE-38680, Not an Issue).\n- **Stale KB** → canned \"wait until contract end-date\" contradicted the authoritative policy (blocked until 6th installment) → reopen + SLA breach (ISSUE-38292).\n- **Ward-merger** → \"Phường Máy Tơ → Gia Viên\"; bot guessed a UI bug (ISSUE-39911).\n\n## Missed easy win (gate too strict here)\n- **ISSUE-40426 (`self_recovered`)** — loan reached FINISH AFTER ticket creation; bot itself recommended close; human added nothing. Safe to auto-close as `communication`. Step 2\'s `self_recovered` class exists for exactly this.\n\n## CTA altitude\nComments overwhelmingly ended in \"chuyển đội kỹ thuật điều tra\", yet most real resolutions were CS instructions (re-apply / pick new ward / wait until due date) the human had to add manually (ISSUE-40089, 40196, 40073, 39947). The mandatory `*Cho KH/CS*` line in the comment format fixes this.\n','2026-06-17 04:44:03','2026-06-17 04:44:03');
INSERT INTO `skill_files` VALUES ('0b4f29aa-a8f2-4454-b0f9-3d98e77487bc','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/cashloan-samples/tnex.csv','mart_skey,id,loan_application_id,user_skey,user_id,partner_code,outstanding_amount,overdue_amount,partner_contract_number,loan_amount,loan_term,loan_info,partner_data,create_at,update_at,sys_effective_date,sys_create_date,settle_at,status\n18403263,856483,20260601-c25648b1-1ada-4265-bac0-66c0756a2101,,211125003002255,TNEX,6000000,0,0101.02.0001321593,6000000,7,\"{\"\"LoanFee\"\":0,\"\"Partner\"\":\"\"TNEX\"\",\"\"Interest\"\":50,\"\"LoanTerm\"\":\"\"7\"\",\"\"ScoreBand\"\":\"\"no_data\"\",\"\"FinalCheck\"\":{\"\"Score\"\":0,\"\"UserIP\"\":\"\"\"\",\"\"DeviceID\"\":\"\"\"\",\"\"DeviceOs\"\":\"\"\"\",\"\"Platform\"\":\"\"\"\",\"\"ScoreBand\"\":\"\"\"\",\"\"UserAgent\"\":\"\"\"\",\"\"AppVersion\"\":\"\"\"\",\"\"ScoreMonth\"\":\"\"\"\",\"\"DeviceModel\"\":\"\"\"\",\"\"UserSegment\"\":\"\"\"\",\"\"ScoreVersion\"\":\"\"\"\",\"\"UserSegments\"\":null},\"\"FirstCheck\"\":{\"\"Score\"\":1,\"\"UserIP\"\":\"\"27.65.53.165\"\",\"\"DeviceID\"\":\"\"2D186177-31EF-4DA5-9982-48FA0DCFEA43\"\",\"\"DeviceOs\"\":\"\"ios\"\",\"\"Platform\"\":\"\"zpa\"\",\"\"ScoreBand\"\":\"\"no_data\"\",\"\"UserAgent\"\":\"\"Mozilla/5.0 (iPhone; CPU iPhone OS 18_7 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Mobile/15E148 ZaloPayClient/11.3.1 OS/26.3.1 Platform/ios Secured/true  ZaloPayWebClient/11.3.1\"\",\"\"AppVersion\"\":\"\"11.3.1\"\",\"\"ScoreMonth\"\":\"\"no_data\"\",\"\"DeviceModel\"\":\"\"iPhone15,4\"\",\"\"UserSegment\"\":\"\"zalopay_bau\"\",\"\"ScoreVersion\"\":\"\"no_data\"\",\"\"UserSegments\"\":[\"\"zalopay_bau\"\"]},\"\"LoanAmount\"\":6000000,\"\"ConsentData\"\":{\"\"sso\"\":true,\"\"consent_content\"\":\"\"\"\"},\"\"ProductCode\"\":\"\"TNEXCL01\"\",\"\"ProductLine\"\":0,\"\"TotalAmount\"\":7532086,\"\"ApprovedTerm\"\":\"\"7\"\",\"\"InsuranceFee\"\":360000,\"\"StartPayDate\"\":\"\"2026-07-01\"\",\"\"ZaloPayScore\"\":\"\"1\"\",\"\"CollectionFee\"\":0,\"\"ApprovedAmount\"\":6000000,\"\"MonthlyInterest\"\":\"\"4.42\"\",\"\"ApprovedInterest\"\":53,\"\"InsurancePartner\"\":\"\"VASS\"\",\"\"InsuranceRegistered\"\":true,\"\"TotalInterestAmount\"\":1172086,\"\"ApprovedInsuranceFee\"\":360000,\"\"MonthlyRepaymentAmount\"\":1076012}\",\"{\"\"upload_kyc_images\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"time\"\":\"\"2026-06-01T06:56:42.3200663+07:00\"\"},\"\"ekyc_images\"\":{\"\"PORTRAIT\"\":{\"\"url\"\":\"\"\"\",\"\"path\"\":\"\"2026/6/1/211125003002255/fc_211125003002255\"\",\"\"content_type\"\":\"\"image/jpeg\"\",\"\"checksum\"\":\"\"e54c86952a3c8244af0d68b87cd2c392\"\"},\"\"NFC\"\":{\"\"url\"\":\"\"\"\",\"\"path\"\":\"\"2026/6/1/211125003002255/avatar_211125003002255\"\",\"\"content_type\"\":\"\"image/jpeg\"\",\"\"checksum\"\":\"\"6e81473a63df17063e7cb5ee37d4ec92\"\"},\"\"IDENTITY_CARD_FRONT\"\":{\"\"url\"\":\"\"\"\",\"\"path\"\":\"\"2026/6/1/211125003002255/front_211125003002255\"\",\"\"content_type\"\":\"\"image/jpeg\"\",\"\"checksum\"\":\"\"8049b19083e53a4e4bab96dc8bbe35ed\"\"},\"\"IDENTITY_CARD_BACK\"\":{\"\"url\"\":\"\"\"\",\"\"path\"\":\"\"2026/6/1/211125003002255/back_211125003002255\"\",\"\"content_type\"\":\"\"image/jpeg\"\",\"\"checksum\"\":\"\"aca9336b7ad888bb98e2ad1940dfeafd\"\"}},\"\"is_enrich_telco_score\"\":true,\"\"full_status\"\":[\"\"AUTHENTICATE\"\",\"\"FORSIGN\"\",\"\"FOR_DISBURSEMENT\"\",\"\"CLOSED\"\"],\"\"registration_id\"\":\"\"abb5af6338c884a55b4d4f5e10ee61b6\"\",\"\"contract_info\"\":{\"\"contract_no\"\":\"\"0101.02.0001321593\"\",\"\"signed_time\"\":\"\"2026-06-01T06:57:33.693619432\"\",\"\"signed_contract_file\"\":\"\"https://fccom-static.tnex.com.vn/contract/Contract_Signed_337cbe56-9f66-4d09-9835-228fa5c1d869_1780271860087.pdf\"\",\"\"contract_file\"\":\"\"https://fccom-static.tnex.com.vn/contract/Contract_UnSigned_337cbe56-9f66-4d09-9835-228fa5c1d869_1780271829299.pdf\"\",\"\"request_id\"\":\"\"260601065709372922\"\",\"\"status\"\":\"\"SIGNED\"\"},\"\"collect_data\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"time\"\":\"\"2026-06-01T06:56:41.280214208+07:00\"\"},\"\"loan_registration\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"time\"\":\"\"2026-06-01T06:56:47.124965571+07:00\"\"},\"\"address_origin\"\":\"\"NFC\"\",\"\"BypassVerifyOTP\"\":false,\"\"retrigger_workflow_info\"\":{},\"\"confirm_registration\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"get_telco_otp_at\"\":\"\"2026-06-01T06:56:53.183289394+07:00\"\",\"\"time\"\":\"\"2026-06-01T06:57:03.562880123+07:00\"\",\"\"request_id\"\":\"\"260601065647009919\"\"},\"\"events\"\":[{\"\"loan_amount\"\":6360000,\"\"event_type\"\":\"\"CALLBACK\"\",\"\"product_id\"\":\"\"64303\"\",\"\"referral_code\"\":\"\"ZALOPAYFE\"\",\"\"loan_approved_amount\"\":0,\"\"event_time\"\":\"\"2026-06-01 06:57:03\"\",\"\"loan_id\"\":\"\"abb5af6338c884a55b4d4f5e10ee61b6\"\",\"\"event_status\"\":\"\"AUTHENTICATE\"\"},{\"\"loan_amount\"\":6360000,\"\"event_type\"\":\"\"CALLBACK\"\",\"\"product_id\"\":\"\"64303\"\",\"\"referral_code\"\":\"\"ZALOPAYFE\"\",\"\"loan_approved_amount\"\":6360000,\"\"event_time\"\":\"\"2026-06-01 06:57:09\"\",\"\"loan_id\"\":\"\"abb5af6338c884a55b4d4f5e10ee61b6\"\",\"\"event_status\"\":\"\"FORSIGN\"\"},{\"\"loan_amount\"\":6360000,\"\"event_type\"\":\"\"CALLBACK\"\",\"\"product_id\"\":\"\"64303\"\",\"\"referral_code\"\":\"\"ZALOPAYFE\"\",\"\"loan_approved_amount\"\":6360000,\"\"event_time\"\":\"\"2026-06-01 06:57:33\"\",\"\"loan_id\"\":\"\"abb5af6338c884a55b4d4f5e10ee61b6\"\",\"\"event_status\"\":\"\"FOR_DISBURSEMENT\"\"},{\"\"loan_amount\"\":6360000,\"\"event_type\"\":\"\"CALLBACK\"\",\"\"product_id\"\":\"\"64303\"\",\"\"referral_code\"\":\"\"ZALOPAYFE\"\",\"\"loan_approved_amount\"\":6360000,\"\"event_time\"\":\"\"2026-06-01 06:57:43\"\",\"\"loan_id\"\":\"\"abb5af6338c884a55b4d4f5e10ee61b6\"\",\"\"event_status\"\":\"\"CLOSED\"\"}],\"\"status\"\":\"\"CLOSED\"\"}\",2026-06-01T00:00:08Z,2026-06-01T00:00:08Z,2026-06-01T00:00:08Z,2026-06-01T00:00:52Z,,1\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('170f2bfd-b9e9-4639-96c9-33274e593261','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/schema-bnpl.md','# Schema: BNPL / Paylater\n\nTables in `datawarehouse` schema covering Paylater (BNPL) fees, transactions, and related entities.\n\n## Table of contents\n\n1. [`datawarehouse.paylater_fee_mart`](#datawarehousepaylater_fee_mart) — Fee charges (service, late fees) for CIMB and LFVN partners\n2. [`datawarehouse.paylater_account_log_mart`](#datawarehousepaylater_account_log_mart) — Transaction log for BNPL purchases, repayments, and refunds\n3. [`datawarehouse.paylater_account_mart_real`](#datawarehousepaylater_account_mart_real) — BNPL account snapshot: credit limits, balances, DPD, status, partner data per user\n\n## Cross-table notes\n\n- **`partner_code` (fee_mart) = `bank_code` (account_log_mart)** — both columns refer to the same partner identity. The same value (e.g., `\'CIMB\'`, `\'LFVN\'`) appears in both. When joining the two tables, you can match on partner using either column.\n- **Always ask which partner** before generating SQL if the user hasn\'t specified one. See the \"Always ask: which partner?\" rule in `SKILL.md`. Don\'t default to all-partners-blended.\n- **`account_id`** is the join key between the two tables (BNPL system\'s user ID — not ZaloPay\'s `user_id`).\n\n---\n\n## `datawarehouse.paylater_fee_mart`\n\n**Description:** Fee charges incurred on Paylater accounts. Covers fees from partner CIMB (`partner_code = \'CIMB\'`) and ZLP-generated-on-behalf-of-LFVN fees (`partner_code = \'LFVN\'`).\n\n**Grain:** One row per *version* of a fee. **Not** one row per fee. See \"Critical: row uniqueness\" below.\n\n### Columns\n\n| Column | Type | Description |\n|---|---|---|\n| `mart_skey` | `bigint` | Surrogate key of the data mart record. **Unique per row** — the only true row-level unique key. |\n| `user_skey` | `bigint` | Internal surrogate key for the user (often NULL in samples — prefer `user_id` for joins until confirmed populated). |\n| `fee_id` | `bigint` | Identifier of the fee instance. **NOT unique** — one fee may have multiple rows due to status updates (append-only). |\n| `account_id` | `bigint` | Identifier of the Paylater/lending account associated with the fee. |\n| `user_id` | `varchar` | ZaloPay user ID, unique identifier for user across tables. |\n| `partner_code` | `varchar` | Partner responsible for charging the fee. Known values: `\'CIMB\'`, `\'LFVN\'`. |\n| `incurred_year_month` | `integer` | Month when the fee is generated, as `YYYYMM` (e.g., `202501`). Useful for fast monthly grouping without timestamp conversion. |\n| `type` | `varchar` | Fee type. Known values: `\'service\'` (service fee, typically 20k VND), late fees (30/60/99/129 — confirm exact `type` strings before filtering). |\n| `amount` | `bigint` | Fee amount in VND. |\n| `description` | `varchar` | Human-readable explanation (Vietnamese for LFVN; empty for CIMB). |\n| `statement_period` | `integer` | Billing/statement period as `YYYYMM`. **`0` for CIMB rows** (CIMB does not populate this). |\n| `payment_status` | `varchar` | `\'paid\'` / `\'unpaid\'` for LFVN. **Always NULL for CIMB.** Updated via append-only logic (new row appended on status change). |\n| `incurred_time` | `timestamp with time zone` | When the fee was charged to the user. **Can be NULL for CIMB rows** — CIMB samples show it blank. |\n| `create_time` | `timestamp with time zone` | When the row was created in the source system. |\n| `update_time` | `timestamp with time zone` | When the row was last updated in the source system. |\n| `sys_effective_date` | `timestamp with time zone` | Warehouse-side effective date for the row. **Do not use for picking the latest version of a fee_id** — use `update_time` instead. |\n| `sys_create_date` | `timestamp with time zone` | When the row was created in the warehouse. |\n\n### Partner-specific behavior — read this every time\n\nLFVN and CIMB rows behave very differently. Filters that seem reasonable will silently exclude one partner:\n\n| Field | LFVN | CIMB |\n|---|---|---|\n| `payment_status` | `\'paid\'` / `\'unpaid\'` | always `NULL` |\n| `description` | populated (Vietnamese) | empty string |\n| `statement_period` | real period (e.g., `202501`) | always `0` |\n| `incurred_time` | populated | **may be NULL** |\n\n**Implications:**\n- `WHERE payment_status = \'paid\'` excludes **all** CIMB rows. If you want \"all CIMB fees + paid LFVN fees\", use `WHERE partner_code = \'CIMB\' OR (partner_code = \'LFVN\' AND payment_status = \'paid\')`.\n- `WHERE statement_period > 0` excludes all CIMB rows.\n- Filtering by `incurred_time` excludes CIMB rows where it\'s NULL — use `COALESCE(incurred_time, create_time)` if you want a fee\'s \"effective date\" across both partners. Or filter by `incurred_year_month` (always populated).\n- Daily/weekly aggregates by partner: prefer `incurred_year_month` for monthly views (always populated, no timezone conversion needed). For finer granularity, use `COALESCE(incurred_time, create_time) AT TIME ZONE \'asia/ho_chi_minh\'`.\n\n### Critical: row uniqueness (append-only)\n\nThis table follows the standard append-only pattern (see \"Append-only tables\" in `SKILL.md`). The business ID is **`fee_id`**, and `mart_skey` is the row-level unique key.\n\n`fee_id` is **NOT unique**. When a fee\'s status changes (e.g., `unpaid` → `paid`), a new row is inserted with the same `fee_id` and a later `update_time`. The same `fee_id` can appear many times.\n\n**Sample evidence:** `fee_id = 106019188` appears 3 times in the data with `mart_skey` 455248, 724467, 2435095 — all CIMB, same user, same amount, different `update_time`.\n\n**Consequence:** `SELECT SUM(amount) FROM paylater_fee_mart` will overcount fees by however many times they\'ve been updated. Apply the standard dedup CTE before any `SUM(amount)`, `COUNT(DISTINCT fee_id)`, or fee-level analysis:\n\n```sql\nWITH latest_fee AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY fee_id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_fee_mart\n        WHERE incurred_year_month >= TO_CHAR(DATEADD(month, -3, CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'), \'YYYYMM\')::INT\n    )\n    WHERE rn = 1\n)\nSELECT * FROM latest_fee;\n```\n\n### Common queries\n\n**Total fees collected by partner, last 3 months (deduped):**\n```sql\nWITH latest_fee AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY fee_id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_fee_mart\n        WHERE incurred_year_month >= TO_CHAR(DATEADD(month, -3, CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'), \'YYYYMM\')::INT\n    )\n    WHERE rn = 1\n)\nSELECT\n    partner_code,\n    type,\n    COUNT(DISTINCT fee_id) AS fee_count,\n    COUNT(DISTINCT user_id) AS user_count,\n    SUM(amount) AS total_amount_vnd\nFROM latest_fee\nGROUP BY partner_code, type\nORDER BY partner_code, total_amount_vnd DESC;\n```\n\n**Paid vs unpaid fees for LFVN, last 3 months:**\n```sql\nWITH latest_fee AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY fee_id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_fee_mart\n        WHERE partner_code = \'LFVN\'\n          AND incurred_year_month >= TO_CHAR(DATEADD(month, -3, CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'), \'YYYYMM\')::INT\n    )\n    WHERE rn = 1\n)\nSELECT\n    incurred_year_month,\n    payment_status,\n    COUNT(DISTINCT fee_id) AS fee_count,\n    SUM(amount) AS total_amount_vnd\nFROM latest_fee\nGROUP BY incurred_year_month, payment_status\nORDER BY incurred_year_month, payment_status;\n```\n\n### Gotchas summary\n\n1. **Append-only table** — apply the standard dedup CTE on `fee_id` ordered by `update_time DESC` before aggregating. See `SKILL.md` for the global rule.\n2. **Don\'t filter on `payment_status`, `statement_period`, or `description`** without thinking about CIMB exclusion.\n3. **`incurred_time` can be NULL** — use `COALESCE(incurred_time, create_time)` or filter by `incurred_year_month`.\n4. **`incurred_year_month` is the cheapest monthly grouping key** — already an integer, no timezone math needed.\n5. **`user_skey` may be NULL** — join on `user_id` (varchar) until confirmed otherwise.\n\n---\n\n## `datawarehouse.paylater_account_log_mart`\n\n**Description:** Transaction log for the BNPL system. One log entry per BNPL transaction event — covers purchases (`trans_type = 200`), repayments (`trans_type = 201`), and refunds (`trans_type = 400`). This is the primary table for BNPL volume, conversion, and repayment behavior analysis.\n\n**Grain:** One row per *version* of a transaction. Append-only — same `id` can appear multiple times as the transaction\'s status updates.\n\n### Columns\n\n| Column | Type | Description |\n|---|---|---|\n| `id` | `bigint` | Unique ID for the BNPL transaction. **Append-only business key** — dedupe with `ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC)`. |\n| `user_skey` | `bigint` | Internal surrogate key for the user. (TBU — populated status unknown; prefer `user_id` for joins.) |\n| `user_id` | `varchar` | ZaloPay user ID. Joins to other ZaloPay tables. |\n| `zp_trans_id` | `varchar` | ZaloPay transaction ID. (TBU — exact role unknown.) |\n| `system_id` | `bigint` | Which system executed the transaction. For repayments (`trans_type = 201`), distinguishes auto-repay vs manual-repay. (Specific values TBU.) |\n| `trans_type` | `bigint` | Transaction category. **`200` = payment (purchase), `201` = repayment, `400` = refund.** |\n| `order_number` | `bigint` | (TBU.) |\n| `partner_trans_id` | `varchar` | Transaction ID from the partner system (matches `bank_code`). |\n| `refund_id` | `varchar` | (TBU — likely populated only for `trans_type = 400`.) |\n| `refund_type` | `varchar` | (TBU.) |\n| `app_trans_id` | `varchar` | (TBU.) |\n| `account_id` | `bigint` | User ID **inside the BNPL system** (not ZaloPay). Joins to `paylater_fee_mart.account_id`. |\n| `user_bank_account_number` | `varchar` | (TBU.) |\n| `bank_code` | `varchar` | Partner bank code. (TBU — confirm canonical values, likely `\'CIMB\'`, `\'LFVN\'`, etc.) |\n| `bank_routing_number` | `varchar` | (TBU.) |\n| `app_id` | `bigint` | The ZaloPay service the user is purchasing from via BNPL (e.g., `241` for IBFT). Use this to slice volume by source app. |\n| `amount` | `bigint` | Transaction amount in VND. |\n| `status` | `varchar` | Final consolidated status from BNPL + partner. Known values: **`\'SUCCEEDED\'`, `\'FAILED\'`, `\'INIT\'`, `\'PROCESSING\'`, `\'UNKNOWN\'`**. For success rate / completed-transaction filters, use `status = \'SUCCEEDED\'` (not `\'SUCCESS\'`). |\n| `bank_status` | `varchar` | Partner-system-only status. May differ from `status` during reconciliation lag. |\n| `version` | `bigint` | (TBU — likely the row version counter for the append-only history.) |\n| `current_available_balance` | `bigint` | (TBU.) |\n| `payment_description` | `varchar` | Order description. |\n| `error_code` | `varchar` | (TBU — populated on `status = \'FAILED\'`.) |\n| `extra` | `varchar` | Additional info (likely JSON or key-value). |\n| `create_time` | `timestamp with time zone` | When the transaction was created in the source system. |\n| `update_time` | `timestamp with time zone` | When the row was last updated in the source system. **Use for append-only dedup ordering.** |\n| `sys_effective_date` | `timestamp with time zone` | Warehouse-side effective date. **Do not use for picking the latest version** — use `update_time`. |\n| `sys_create_date` | `timestamp with time zone` | When the row was created in the warehouse. |\n| `payment_no` | `varchar` | (TBU.) |\n| `device_id` | `varchar` | (TBU.) |\n| `platform` | `varchar` | (TBU — likely `ios` / `android` / `web`.) |\n\n### Mandatory filters\n\nApply this unless the user explicitly overrides:\n\n- **Date filter on `create_time`** (or `update_time` if the user wants \"transactions updated in window\") — last 3 months by default per the global SQL conventions.\n\n### Critical: row uniqueness (append-only)\n\nThis table follows the standard append-only pattern (see \"Append-only tables\" in `SKILL.md`). The business ID is **`id`** (yes — `id` is both the unique transaction identifier and the dedup key; the row-level uniqueness comes from `id` + `update_time` together).\n\nWhen a transaction\'s `status` or `bank_status` changes (e.g., `PENDING` → `SUCCESS`), a new row is inserted with the same `id` and a later `update_time`.\n\n**Apply the standard dedup CTE before any `SUM(amount)`, `COUNT(DISTINCT id)`, or transaction-level analysis:**\n\n```sql\nWITH latest_txn AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_log_mart\n          WHERE create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT * FROM latest_txn;\n```\n\n### `trans_type` reference (use frequently)\n\n| `trans_type` | Meaning | When to use |\n|---|---|---|\n| `200` | Payment (BNPL purchase) | Purchase volume, conversion, app-level slicing |\n| `201` | Repayment | Repayment behavior, on-time vs late, auto vs manual (via `system_id`) |\n| `400` | Refund | Refund rate, refund volume |\n\n### Common queries\n\n**BNPL purchase volume by month, last 3 months (production only, deduped):**\n\n```sql\nWITH latest_txn AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_log_mart\n          WHERE trans_type = 200\n          AND create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT\n    DATE_TRUNC(\'month\', create_time AT TIME ZONE \'asia/ho_chi_minh\') AS month_vn,\n    COUNT(DISTINCT id) AS purchase_count,\n    COUNT(DISTINCT user_id) AS active_users,\n    SUM(CASE WHEN status = \'SUCCEEDED\' THEN amount ELSE 0 END) AS successful_volume_vnd,\n    ROUND(100.0 * COUNT(DISTINCT CASE WHEN status = \'SUCCEEDED\' THEN id END)\n                / NULLIF(COUNT(DISTINCT id), 0), 2) AS success_rate_pct\nFROM latest_txn\nGROUP BY 1\nORDER BY 1;\n```\n\n**Repayment auto vs manual split (uses `system_id`):**\n\n```sql\n-- Note: system_id values for auto vs manual TBU. Confirm exact values before reading the result.\nWITH latest_repay AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_log_mart\n          WHERE trans_type = 201\n          AND create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT\n    DATE_TRUNC(\'month\', create_time AT TIME ZONE \'asia/ho_chi_minh\') AS month_vn,\n    system_id,\n    COUNT(DISTINCT id) AS repay_count,\n    COUNT(DISTINCT user_id) AS repaying_users,\n    SUM(CASE WHEN status = \'SUCCEEDED\' THEN amount ELSE 0 END) AS successful_repay_vnd\nFROM latest_repay\nGROUP BY 1, 2\nORDER BY 1, 2;\n```\n\n**Joining to fee table (purchases that incurred fees):**\n\n```sql\n-- account_id is the join key between log_mart and fee_mart.\nWITH latest_txn AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_log_mart\n          WHERE trans_type = 200\n          AND status = \'SUCCEEDED\'\n          AND create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n),\nlatest_fee AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY fee_id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_fee_mart\n        WHERE incurred_year_month >= TO_CHAR(DATEADD(month, -3, CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'), \'YYYYMM\')::INT\n    )\n    WHERE rn = 1\n)\nSELECT\n    t.user_id,\n    COUNT(DISTINCT t.id) AS purchase_count,\n    SUM(t.amount) AS purchase_volume_vnd,\n    COUNT(DISTINCT f.fee_id) AS fee_count,\n    SUM(f.amount) AS fee_amount_vnd\nFROM latest_txn t\nLEFT JOIN latest_fee f ON t.account_id = f.account_id\nGROUP BY t.user_id\nORDER BY purchase_volume_vnd DESC\nLIMIT 100;\n```\n\n### Gotchas summary\n\n1. **Append-only table** — apply the standard dedup CTE on `id` ordered by `update_time DESC` before aggregating. See `SKILL.md` for the global rule.\n2. **`trans_type` is mandatory context** — never aggregate `amount` without filtering or grouping by `trans_type`. Mixing purchases (200), repayments (201), and refunds (400) produces meaningless totals.\n3. **`status` vs `bank_status`** — `status` is the consolidated final status (use this for funnels, success rates). `bank_status` is partner-system-only and may lag during reconciliation. Don\'t use them interchangeably.\n4. **`status` enum is `SUCCEEDED` (not `SUCCESS`)** — common mistake. Full set: `SUCCEEDED`, `FAILED`, `INIT`, `PROCESSING`, `UNKNOWN`. `INIT` and `PROCESSING` are in-flight states (transaction started but not yet resolved) — exclude them from success-rate denominators only if you want a \"completed transactions\" view; include them if you want \"all attempts.\"\n5. **`account_id` is the BNPL system\'s user ID, not ZaloPay\'s** — it\'s the join key to `paylater_fee_mart.account_id`. For joining to ZaloPay tables, use `user_id`.\n6. **`app_id`** — slice by `app_id` to attribute BNPL volume to specific ZaloPay services (e.g., `app_id = 241` for IBFT).\n7. **Many TBU columns** — `zp_trans_id`, `app_trans_id`, `order_number`, `system_id` values, `bank_code` enum, etc., are not yet documented. If a query depends on these, flag the assumption or ask the user.\n\n---\n\n## `datawarehouse.paylater_account_mart_real`\n\n**Description:** Account-level snapshot table for BNPL (Paylater). Each row represents one version of a user\'s BNPL account with a specific lending partner — credit limit, available balance, outstanding debt, days past due, NFC/eKYC status, and partner-synced balance data. This is the primary table for account health, credit utilization, overdue monitoring, and user-level account status queries.\n\n**Grain:** One row per *version* of an account. **Append-only** — same `id` can appear multiple times as the account state changes. Dedupe on `id` ordered by `update_time DESC` before any aggregation.\n\n**Partners known in data:** `CIMB` (confirmed in sample). Also likely: `CAKE`, `TNEX`, `SHB` (per `bank_code` description).\n\n### Columns\n\n#### Core account fields\n\n| Column | Type | Description |\n|---|---|---|\n| `user_skey` | `integer` | Internal surrogate key for user. **Often NULL in practice** — prefer `user_id` for joins. |\n| `user_id` | `varchar` | ZaloPay user ID. Primary join key to other ZaloPay tables. |\n| `id` | `bigint` | BNPL account ID. **Append-only business key** — dedupe with `ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC)`. One `user_id` can have multiple `id`s (one per partner). |\n| `create_time` | `timestamp with time zone` | When this account was first created in the source system. **Use for cohort / activation date analysis.** |\n| `update_time` | `timestamp with time zone` | When this row was last updated in the source system. **Use for append-only dedup ordering — not `sys_effective_date`.** |\n| `bank_code` | `varchar` | Partner/bank code. Known values: `\'CIMB\'`, `\'CAKE\'`, `\'TNEX\'`, `\'SHB\'`. This is the same partner identity as `partner_code` in `paylater_fee_mart`. |\n| `bank_account_number` | `varchar` | Account number at the lending partner bank (may be encrypted/masked in some rows). |\n| `bank_account_name` | `varchar` | Account holder name registered at the lending partner bank. |\n| `status` | `varchar` | Account status. Known values: `\'active\'`, `\'inactive\'`, `\'locked\'`. Use `status = \'active\'` for \"current active accounts\". |\n| `total_limit` | `bigint` | Maximum credit limit of the account in VND (smallest unit). |\n| `available_balance` | `bigint` | Remaining credit the user can spend on new purchases. Utilization = `(total_limit - available_balance) / total_limit`. |\n| `version` | `bigint` | Row version counter for optimistic locking / change tracking. |\n| `extra` | `varchar` | JSON blob with extended fields. Key sub-fields documented below. |\n| `sys_effective_date` | `timestamp with time zone` | Warehouse-side effective date. **Do not use for picking the latest version** — use `update_time`. |\n| `sys_create_date` | `timestamp with time zone` | When the row was inserted into the data warehouse. |\n| `zalo_id` | `bigint` | Zalo social platform user ID linked to this ZaloPay account. |\n\n#### Debt / repayment health fields\n\n| Column | Type | Description |\n|---|---|---|\n| `day_past_due` | `bigint` | Number of days the user has not repaid their due amount. `0` = current. `> 0` = overdue. Key field for delinquency / DPD bucketing. |\n| `day_past_due_update_time` | `varchar` | Timestamp of the last DPD update (stored as varchar — cast with `CAST(day_past_due_update_time AS timestamp)` if needed). |\n| `outstanding_balance` | `bigint` | Total outstanding debt as of `outstanding_balance_update_time`. In VND smallest unit. |\n| `outstanding_balance_update_time` | `varchar` | Timestamp of the last outstanding balance update (varchar — cast if needed). |\n| `over_repayment_balance` | `bigint` | Extra amount the user has repaid beyond their outstanding debt. Positive = user overpaid. |\n| `overdraft_expiry_date` | `varchar` | Expiry date of any overdraft facility on the account (varchar). |\n\n#### Account lifecycle fields\n\n| Column | Type | Description |\n|---|---|---|\n| `renew_eligible` | `varchar` | Whether the account is eligible for limit renewal. Values TBU from data — confirm before filtering. |\n| `expiration_time` | `varchar` | Expiry timestamp of the account. Sample shows `2027-01-01 21:00:00.0` format (VN time). |\n| `nfc_status` | `varchar` | NFC eKYC verification status. Known values: `\'valid\'`, likely others. |\n| `agree_consent_bank_time` | `timestamp with time zone` | When the user consented to share data with the bank partner. Used for registration / binding time analysis. |\n\n#### `extra` JSON sub-fields (accessed via JSON extraction or pre-parsed columns)\n\nThese fields live inside the `extra` JSON column. In Redshift, access them with `JSON_EXTRACT_PATH_TEXT(extra, \'field_name\')`. They are documented here for query planning.\n\n| Sub-field path | Type | Description |\n|---|---|---|\n| `extra.user_fee` | `bigint` | Fee charged to user (VND). `0` if no fee applied. |\n| `extra.user_fee_date` | `timestamp` | Date when `user_fee` was last charged. |\n| `extra.binding_log_id` | `bigint` | Log ID of the account binding event that created this account. |\n| `extra.due_pay_amount` | `bigint` | Amount due for the current billing cycle (VND). |\n| `extra.maintenance_fee` | `bigint` | Monthly maintenance fee charged on the account (VND). |\n| `extra.maintenance_fee_date` | `timestamp` | Date when `maintenance_fee` was last charged. |\n| `extra.outstanding_balance` | `bigint` | Mirror of root-level `outstanding_balance` stored in extra. |\n| `extra.over_repayment_balance` | `bigint` | Mirror of root-level `over_repayment_balance` stored in extra. |\n| `extra.ob_updated_time` | `timestamp` | Timestamp of the last outstanding balance update as recorded in extra. |\n| `extra.available_balance_updated_time` | `timestamp` | Timestamp of the last available balance sync stored in extra. |\n| `extra.partner_account_status` | `varchar` | Account status as reported by the partner. Known values: `\'NORMAL\'`, likely `\'LOCKED\'`. |\n| `extra.debt_settlement.partner_code` | `varchar` | Partner code for debt settlement (e.g., `\'CIMB\'`). |\n| `extra.debt_settlement.partner_data.statement_date` | `integer` | Day of month the partner generates the billing statement. |\n| `extra.debt_settlement.partner_data.statement_graceful_date` | `integer` | Grace period (days) after `statement_date` before late fees apply. |\n\n**`extra.balance_partner_data` sub-object** — latest balance data synced from partner:\n\n| Sub-field | Type | Description |\n|---|---|---|\n| `extra.balance_partner_data.od_status` | `varchar` | Overdraft status from partner. Known values: `\'NORMAL\'`, `\'OVERDUE\'`. |\n| `extra.balance_partner_data.total_limit` | `bigint` | Total credit limit per partner balance sync. |\n| `extra.balance_partner_data.days_past_due` | `integer` | DPD per partner balance sync. |\n| `extra.balance_partner_data.due_pay_amount` | `bigint` | Amount due per partner balance sync. |\n| `extra.balance_partner_data.available_balance` | `bigint` | Available balance per partner balance sync. |\n| `extra.balance_partner_data.outstanding_balance` | `bigint` | Outstanding balance per partner balance sync. |\n| `extra.balance_partner_data.over_repayment_balance` | `bigint` | Over-repayment balance per partner balance sync. |\n| `extra.balance_partner_data.bank_account_number` | `varchar` | Partner bank account number from balance sync. |\n| `extra.balance_partner_data.pay_later_outstanding_balance` | `bigint` | BNPL (Pay Later) component of outstanding balance. |\n| `extra.balance_partner_data.installment_outstanding_balance` | `bigint` | Installment component of outstanding balance. |\n| `extra.balance_partner_data.days_past_due_updated_time` | `timestamp` | Timestamp of DPD value in partner balance sync. |\n| `extra.balance_partner_data.available_balance_updated_time` | `timestamp` | Timestamp of available_balance in partner balance sync. |\n| `extra.balance_partner_data.outstanding_balance_updated_time` | `timestamp` | Timestamp of outstanding_balance in partner balance sync. |\n\n**`extra.partner_account_data` sub-object** — account metadata from partner:\n\n| Sub-field | Type | Description |\n|---|---|---|\n| `extra.partner_account_data.od_status` | `varchar` | Overdraft status from partner account data. |\n| `extra.partner_account_data.total_limit` | `bigint` | Total credit limit per partner account data. |\n| `extra.partner_account_data.available_balance` | `bigint` | Available balance per partner account data. |\n| `extra.partner_account_data.bank_account_number` | `varchar` | Partner bank account number from partner account data. |\n| `extra.partner_account_data.bank_account_name` | `varchar` | Account holder full name at partner bank. |\n| `extra.partner_account_data.expiration_time` | `bigint` | Account expiration as Unix epoch (seconds). |\n| `extra.partner_account_data.migrated_at` | `bigint` | Migration epoch; `0` if not migrated from another system. |\n| `extra.partner_account_data.cimb_dual_pilot` | `boolean` | **CIMB-specific.** Dual-pilot account mode flag. |\n| `extra.partner_account_data.cimb_account_type` | `varchar` | **CIMB-specific.** Account type identifier; empty string if not applicable. |\n\n### Critical: row uniqueness (append-only)\n\nThis table follows the standard append-only pattern (see \"Append-only tables\" in `SKILL.md`). The business key is **`id`** (the BNPL account ID).\n\nWhen an account\'s state changes (balance sync, status update, DPD update), a new row is inserted with the same `id` and a later `update_time`. **Do not aggregate without deduping.**\n\n```sql\nWITH latest_account AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_mart_real\n        WHERE create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT * FROM latest_account;\n```\n\n**Note on date filter:** `create_time` is the account opening date. For balance/DPD snapshots you often want **all active accounts** regardless of when they opened — in that case, **drop the `create_time` filter** and filter on `status = \'active\'` instead. Only use the date window when you\'re doing activation-cohort analysis.\n\n### Key relationships\n\n| This table | Joins to | Via |\n|---|---|---|\n| `paylater_account_mart_real` | `paylater_fee_mart` | `id` = `paylater_fee_mart.account_id` |\n| `paylater_account_mart_real` | `paylater_account_log_mart` | `id` = `paylater_account_log_mart.account_id` |\n| `paylater_account_mart_real` | ZaloPay user tables | `user_id` |\n\n`bank_code` here is the same partner identity as `partner_code` in `paylater_fee_mart` and `bank_code` in `paylater_account_log_mart`.\n\n### Common queries\n\n**Active accounts by partner with credit utilization, current snapshot:**\n\n```sql\nWITH latest_account AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_mart_real\n    )\n    WHERE rn = 1\n)\nSELECT\n    bank_code,\n    COUNT(DISTINCT id)                                                       AS account_count,\n    COUNT(DISTINCT user_id)                                                  AS user_count,\n    SUM(total_limit)                                                         AS total_limit_vnd,\n    SUM(available_balance)                                                   AS total_available_vnd,\n    SUM(outstanding_balance)                                                 AS total_outstanding_vnd,\n    ROUND(100.0 * SUM(total_limit - available_balance)\n          / NULLIF(SUM(total_limit), 0), 2)                                 AS utilization_pct\nFROM latest_account\nWHERE status = \'active\'\nGROUP BY bank_code\nORDER BY account_count DESC;\n```\n\n**DPD bucket distribution (overdue monitoring), current snapshot:**\n\n```sql\nWITH latest_account AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_mart_real\n    )\n    WHERE rn = 1\n)\nSELECT\n    bank_code,\n    CASE\n        WHEN day_past_due = 0              THEN \'0 - current\'\n        WHEN day_past_due BETWEEN 1 AND 7  THEN \'1-7 days\'\n        WHEN day_past_due BETWEEN 8 AND 30 THEN \'8-30 days\'\n        WHEN day_past_due BETWEEN 31 AND 60 THEN \'31-60 days\'\n        WHEN day_past_due > 60             THEN \'60+ days\'\n        ELSE \'unknown\'\n    END                                        AS dpd_bucket,\n    COUNT(DISTINCT id)                         AS account_count,\n    COUNT(DISTINCT user_id)                    AS user_count,\n    SUM(outstanding_balance)                   AS outstanding_vnd\nFROM latest_account\nWHERE status = \'active\'\nGROUP BY bank_code, dpd_bucket\nORDER BY bank_code, dpd_bucket;\n```\n\n**New account activations by month (cohort opening date):**\n\n```sql\nWITH latest_account AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_mart_real\n        WHERE create_time AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT\n    DATE_TRUNC(\'month\', create_time AT TIME ZONE \'asia/ho_chi_minh\') AS activation_month,\n    bank_code,\n    COUNT(DISTINCT id)                                                AS new_accounts,\n    COUNT(DISTINCT user_id)                                           AS new_users\nFROM latest_account\nGROUP BY 1, 2\nORDER BY 1, 2;\n```\n\n**Joining to fee mart — outstanding debt + fees incurred for overdue users:**\n\n```sql\nWITH latest_account AS (\n    SELECT *\n    FROM (\n        SELECT *,\n               ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_account_mart_real\n    )\n    WHERE rn = 1\n),\nlatest_fee AS (\n    SELECT *\n    FROM (\n        SELECT *,\n               ROW_NUMBER() OVER (PARTITION BY fee_id ORDER BY update_time DESC) AS rn\n        FROM datawarehouse.paylater_fee_mart\n        WHERE incurred_year_month >= TO_CHAR(DATEADD(month, -3, CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'), \'YYYYMM\')::INT\n    )\n    WHERE rn = 1\n)\nSELECT\n    a.bank_code,\n    a.user_id,\n    a.day_past_due,\n    a.outstanding_balance,\n    COUNT(DISTINCT f.fee_id) AS fee_count,\n    SUM(f.amount)            AS total_fees_vnd\nFROM latest_account a\nLEFT JOIN latest_fee f ON a.id = f.account_id\nWHERE a.status = \'active\'\n  AND a.day_past_due > 0\nGROUP BY a.bank_code, a.user_id, a.day_past_due, a.outstanding_balance\nORDER BY a.day_past_due DESC, a.outstanding_balance DESC;\n```\n\n### Gotchas summary\n\n1. **Append-only table** — dedupe on `id` ordered by `update_time DESC` before any aggregation. See `SKILL.md`.\n2. **`create_time` filter is cohort-scoped** — for current-state balance/DPD analysis, drop the date window and filter on `status = \'active\'` instead. Adding a 3-month `create_time` filter will exclude long-standing accounts opened before the window.\n3. **`extra` is a raw JSON string** — use `JSON_EXTRACT_PATH_TEXT(extra, \'key\')` in Redshift. Nested paths: `JSON_EXTRACT_PATH_TEXT(extra, \'balance_partner_data\', \'days_past_due\')`.\n4. **`day_past_due_update_time` and `outstanding_balance_update_time` are varchar** — cast explicitly: `CAST(day_past_due_update_time AS timestamp)`.\n5. **`user_skey` is often NULL** — always join on `user_id` (varchar).\n6. **Partner ask rule applies** — if the query touches `bank_code` and the user hasn\'t specified a partner, ask before generating SQL. Same rule as other BNPL tables.\n8. **`id` here = `account_id` in `paylater_fee_mart` and `paylater_account_log_mart`** — this is the join key between the three tables.\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('195b168b-8e82-4ae2-906b-1815e73bf8cf','f1eab81b-eedc-455d-8b19-dccdd3d0754e','e29a2cb8-d3ca-42c0-bf91-fbfa6cebb852','rules/commit_rules.md','# Conventional Commits Formatting Guidelines\n\n## Structure\nCommit messages must follow this structure:\n<type>[optional scope]: <description>\n\n[optional body]\n\n[optional footer(s)]\n\n\n## Allowed Types (Prefixes)\n- **feat**: A new feature\n- **fix**: A bug fix\n- **docs**: Documentation only changes\n- **style**: Changes that do not affect the meaning of the code (white-space, formatting, missing semi-colons, etc)\n- **refactor**: A code change that neither fixes a bug nor adds a feature\n- **perf**: A code change that improves performance\n- **test**: Adding missing tests or correcting existing tests\n- **build**: Changes that affect the build system or external dependencies (example scopes: gulp, broccoli, npm)\n- **ci**: Changes to our CI configuration files and scripts (example scopes: Travis, Circle, BrowserStack, SauceLabs)\n- **chore**: Other changes that don\'t modify src or test files\n- **revert**: Reverts a previous commit\n\n## Formatting Rules\n1. **Description**: \n   - Use the imperative, present tense: \"change\" not \"changed\" nor \"changes\".\n   - Do not capitalize the first letter.\n   - No dot (.) at the end.\n   - Keep it concise (under 50 characters if possible).\n2. **Scope**: \n   - Should be a noun indicating the section of the codebase being modified (e.g., `feat(auth): add login`).\n3. **Body**: \n   - Use the imperative, present tense.\n   - Wrap text at 72 characters.\n   - Explain the motivation for the change and contrast this with previous behavior.\n4. **Breaking Changes**:\n   - MUST be indicated by an `!` after the type/scope (e.g., `feat(api)!: remove deprecated endpoint`) OR in the footer starting with `BREAKING CHANGE: `.','2026-06-09 18:17:47','2026-06-09 18:17:47');
INSERT INTO `skill_files` VALUES ('44b50ecf-ab47-4e7b-902a-5978574cfc0f','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/cashloan-samples/cake.csv','mart_skey,id,loan_application_id,user_skey,user_id,partner_code,outstanding_amount,overdue_amount,partner_contract_number,loan_amount,loan_term,loan_info,partner_data,create_at,update_at,sys_effective_date,sys_create_date,settle_at,status\n18403323,856516,20260531-ab50e2d8-83be-4379-9eeb-5a78bab71e13,,210724000502133,CAKE,12000000,0,zDFzw9LL5ggPhcAYadza,12000000,18,\"{\"\"LoanFee\"\":0,\"\"Partner\"\":\"\"CAKE\"\",\"\"Interest\"\":55,\"\"LoanTerm\"\":\"\"18\"\",\"\"ScoreBand\"\":\"\"no_data\"\",\"\"FinalCheck\"\":{\"\"Score\"\":0,\"\"UserIP\"\":\"\"\"\",\"\"DeviceID\"\":\"\"\"\",\"\"DeviceOs\"\":\"\"\"\",\"\"Platform\"\":\"\"\"\",\"\"ScoreBand\"\":\"\"\"\",\"\"UserAgent\"\":\"\"\"\",\"\"AppVersion\"\":\"\"\"\",\"\"ScoreMonth\"\":\"\"\"\",\"\"DeviceModel\"\":\"\"\"\",\"\"UserSegment\"\":\"\"\"\",\"\"ScoreVersion\"\":\"\"\"\",\"\"UserSegments\"\":null},\"\"FirstCheck\"\":{\"\"Score\"\":1,\"\"UserIP\"\":\"\"14.191.229.96\"\",\"\"DeviceID\"\":\"\"D8D33511-7BF7-4846-A4D5-C4C6B0BEEE4C\"\",\"\"DeviceOs\"\":\"\"ios\"\",\"\"Platform\"\":\"\"zpa\"\",\"\"ScoreBand\"\":\"\"no_data\"\",\"\"UserAgent\"\":\"\"Mozilla/5.0 (iPhone; CPU iPhone OS 26_0_1 like Mac OS X) AppleWebKit/8622.1.22.10.11, Copyright 2003-2025 Apple Inc. (KHTML, like Gecko) Mobile/23A354 ZaloPayClient/11.3.1 ZaloPayWebClient/11.3.1 OS/26.0.1 Platform/ios Secured/true\"\",\"\"AppVersion\"\":\"\"11.3.1\"\",\"\"ScoreMonth\"\":\"\"no_data\"\",\"\"DeviceModel\"\":\"\"iPhone18,1\"\",\"\"UserSegment\"\":\"\"zalopay_bau\"\",\"\"ScoreVersion\"\":\"\"no_data\"\",\"\"UserSegments\"\":[\"\"zalopay_bau\"\"]},\"\"LoanAmount\"\":25000000,\"\"ConsentData\"\":{\"\"sso\"\":true,\"\"consent_content\"\":\"\"Bằng cách nhấn “Đăng ký ngay”, tôi đồng ý với Chính sách bảo vệ quyền riêng tư của Zalopay và cho phép Zalopay thu thập, sử dụng, và chia sẻ các thông tin hiện có hoặc được cung cấp trong quá trình sử dụng dịch vụ cho các bên liên quan nhằm thực hiện các dịch vụ yêu cầu.\"\"},\"\"ProductCode\"\":\"\"ZLPCL01\"\",\"\"ProductLine\"\":0,\"\"TotalAmount\"\":17881327,\"\"ApprovedTerm\"\":\"\"18\"\",\"\"InsuranceFee\"\":0,\"\"StartPayDate\"\":\"\"2026-07-01\"\",\"\"ZaloPayScore\"\":\"\"1\"\",\"\"CollectionFee\"\":0,\"\"ApprovedAmount\"\":12000000,\"\"MonthlyInterest\"\":\"\"4.58\"\",\"\"ApprovedInterest\"\":55,\"\"InsurancePartner\"\":null,\"\"InsuranceRegistered\"\":false,\"\"TotalInterestAmount\"\":5881327,\"\"ApprovedInsuranceFee\"\":0,\"\"MonthlyRepaymentAmount\"\":993407}\",\"{\"\"upload_kyc_images\"\":{},\"\"full_status\"\":[\"\"EKYC_SUCCESS\"\",\"\"LOAN_REVIEWING\"\",\"\"LOAN_APPROVE\"\",\"\"LOAN_ACTIVE\"\"],\"\"registration_id\"\":\"\"\"\",\"\"contract_info\"\":{},\"\"collect_data\"\":{},\"\"loan_registration\"\":{},\"\"address_origin\"\":\"\"\"\",\"\"BypassVerifyOTP\"\":false,\"\"retrigger_workflow_info\"\":{},\"\"confirm_registration\"\":{},\"\"loan_detail\"\":{\"\"penalty_principal_balance\"\":\"\"0\"\",\"\"principle_balance\"\":\"\"12000000\"\",\"\"penalty_interest_balance\"\":\"\"0\"\",\"\"monthly_payment_amount\"\":\"\"0\"\",\"\"due_date\"\":\"\"2026-07-01\"\",\"\"disburse_date\"\":\"\"2026-06-01\"\",\"\"total_payment_amount\"\":\"\"0\"\",\"\"approved_term\"\":\"\"18\"\",\"\"day_arrears\"\":\"\"0\"\",\"\"disburse_amount\"\":\"\"12000000\"\",\"\"paid_amount\"\":\"\"0\"\",\"\"payment_period\"\":\"\"1\"\",\"\"interest_rate\"\":\"\"55\"\",\"\"loan_account_status\"\":\"\"LOAN_ACTIVE\"\",\"\"prepayment_amount\"\":\"\"0\"\",\"\"approved_amount\"\":\"\"12000000\"\",\"\"interest_balance\"\":\"\"0\"\"},\"\"events\"\":null,\"\"status\"\":\"\"\"\"}\",2026-06-01T00:05:28Z,2026-06-01T00:05:28Z,2026-06-01T00:05:28Z,2026-06-01T00:08:50Z,,1\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('5593cc3e-fdfc-45c4-b5b1-924ab9e83ff3','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/query-patterns.md','# Query Patterns (Redshift, ZaloPay)\n\nReusable analytical query shapes. Adapt the column names to the actual schema — these are skeletons.\n\nAll patterns follow the SQL conventions in `SKILL.md`: timezone conversion, last-3-months date filter, `COUNT(DISTINCT user_id)` for user metrics, CTEs over subqueries.\n\n## Table of contents\n\n1. [Monthly cohort retention](#1-monthly-cohort-retention)\n2. [Funnel conversion](#2-funnel-conversion)\n3. [MoM / DoD trend with growth rate](#3-mom--dod-trend-with-growth-rate)\n4. [Blended rate vs baseline](#4-blended-rate-vs-baseline)\n5. [User segmentation by behavior](#5-user-segmentation-by-behavior)\n6. [Partner-level breakdown](#6-partner-level-breakdown)\n\n---\n\n## 1. Monthly cohort retention\n\nFor \"how many users from cohort X are still active in month X+N?\"\n\n```sql\nWITH first_txn AS (\n    -- First transaction date per user (defines cohort)\n    SELECT\n        user_id,\n        DATE_TRUNC(\'month\', MIN(created_at) AT TIME ZONE \'asia/ho_chi_minh\') AS cohort_month\n    FROM <transactions_table>\n    WHERE created_at AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -6, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n      AND status = \'SUCCESS\'\n    GROUP BY user_id\n),\nactivity AS (\n    -- Distinct active months per user\n    SELECT DISTINCT\n        user_id,\n        DATE_TRUNC(\'month\', created_at AT TIME ZONE \'asia/ho_chi_minh\') AS active_month\n    FROM <transactions_table>\n    WHERE status = \'SUCCESS\'\n),\ncohort_activity AS (\n    SELECT\n        ft.cohort_month,\n        a.active_month,\n        DATEDIFF(month, ft.cohort_month, a.active_month) AS months_since_cohort,\n        COUNT(DISTINCT a.user_id) AS retained_users\n    FROM first_txn ft\n    INNER JOIN activity a ON ft.user_id = a.user_id\n    WHERE a.active_month >= ft.cohort_month\n    GROUP BY ft.cohort_month, a.active_month\n)\nSELECT\n    cohort_month,\n    months_since_cohort,\n    retained_users\nFROM cohort_activity\nORDER BY cohort_month, months_since_cohort;\n```\n\n**Notes:** For retention *rate*, divide by cohort size (`SELECT cohort_month, COUNT(DISTINCT user_id) FROM first_txn GROUP BY 1`).\n\n---\n\n## 2. Funnel conversion\n\nFor \"step 1 → step 2 → step 3 conversion rates.\"\n\n```sql\nWITH step1 AS (\n    SELECT DISTINCT user_id\n    FROM <event_table>\n    WHERE event_name = \'<step1_event>\'\n      AND event_time AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n),\nstep2 AS (\n    SELECT DISTINCT user_id\n    FROM <event_table>\n    WHERE event_name = \'<step2_event>\'\n      AND event_time AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n),\nstep3 AS (\n    SELECT DISTINCT user_id\n    FROM <event_table>\n    WHERE event_name = \'<step3_event>\'\n      AND event_time AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n)\nSELECT\n    (SELECT COUNT(DISTINCT user_id) FROM step1) AS step1_users,\n    (SELECT COUNT(DISTINCT user_id) FROM step2) AS step2_users,\n    (SELECT COUNT(DISTINCT user_id) FROM step3) AS step3_users,\n    ROUND(100.0 * (SELECT COUNT(DISTINCT user_id) FROM step2) / NULLIF((SELECT COUNT(DISTINCT user_id) FROM step1), 0), 2) AS step1_to_2_pct,\n    ROUND(100.0 * (SELECT COUNT(DISTINCT user_id) FROM step3) / NULLIF((SELECT COUNT(DISTINCT user_id) FROM step2), 0), 2) AS step2_to_3_pct;\n```\n\n**Note:** Strict funnel (user must do steps in order with timestamps respected) requires joining on user_id with `event_time` comparison instead. Ask the user which they want if unclear.\n\n---\n\n## 3. MoM / DoD trend with growth rate\n\nFor \"show me [metric] by month with growth rate.\"\n\n```sql\nWITH monthly AS (\n    SELECT\n        DATE_TRUNC(\'month\', created_at AT TIME ZONE \'asia/ho_chi_minh\') AS month_vn,\n        COUNT(DISTINCT user_id) AS active_users,\n        SUM(amount) AS total_volume\n    FROM <transactions_table>\n    WHERE created_at AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -6, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n      AND status = \'SUCCESS\'\n    GROUP BY 1\n)\nSELECT\n    month_vn,\n    active_users,\n    total_volume,\n    LAG(active_users) OVER (ORDER BY month_vn) AS prev_month_users,\n    ROUND(100.0 * (active_users - LAG(active_users) OVER (ORDER BY month_vn))\n                / NULLIF(LAG(active_users) OVER (ORDER BY month_vn), 0), 2) AS user_mom_pct,\n    ROUND(100.0 * (total_volume - LAG(total_volume) OVER (ORDER BY month_vn))\n                / NULLIF(LAG(total_volume) OVER (ORDER BY month_vn), 0), 2) AS volume_mom_pct\nFROM monthly\nORDER BY month_vn;\n```\n\nFor DoD, swap `\'month\'` → `\'day\'` and adjust the date window.\n\n---\n\n## 4. Blended rate vs baseline\n\nFor \"what\'s the conversion rate of feature X vs baseline?\" (e.g., AgreementPay × BNPL uplift).\n\n```sql\nWITH treatment AS (\n    SELECT\n        COUNT(DISTINCT user_id) AS exposed_users,\n        COUNT(DISTINCT CASE WHEN converted = TRUE THEN user_id ELSE NULL END) AS converted_users\n    FROM <treatment_table>\n    WHERE event_time AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n),\nbaseline AS (\n    SELECT\n        COUNT(DISTINCT user_id) AS exposed_users,\n        COUNT(DISTINCT CASE WHEN converted = TRUE THEN user_id ELSE NULL END) AS converted_users\n    FROM <baseline_table>\n    WHERE event_time AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n)\nSELECT\n    \'treatment\' AS group_name,\n    exposed_users,\n    converted_users,\n    ROUND(100.0 * converted_users / NULLIF(exposed_users, 0), 2) AS conversion_pct\nFROM treatment\nUNION ALL\nSELECT\n    \'baseline\',\n    exposed_users,\n    converted_users,\n    ROUND(100.0 * converted_users / NULLIF(exposed_users, 0), 2)\nFROM baseline;\n```\n\n---\n\n## 5. User segmentation by behavior\n\nFor \"split users into segments based on what products they used\" (e.g., inst-only, pl-only, inst×pl).\n\n```sql\nWITH user_products AS (\n    SELECT\n        user_id,\n        MAX(CASE WHEN product_type = \'inst\' THEN 1 ELSE 0 END) AS used_inst,\n        MAX(CASE WHEN product_type = \'pl\'   THEN 1 ELSE 0 END) AS used_pl\n    FROM <transactions_table>\n    WHERE created_at AT TIME ZONE \'asia/ho_chi_minh\'\n          >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n      AND status = \'SUCCESS\'\n    GROUP BY user_id\n),\nsegmented AS (\n    SELECT\n        user_id,\n        CASE\n            WHEN used_inst = 1 AND used_pl = 1 THEN \'inst_x_pl\'\n            WHEN used_inst = 1 AND used_pl = 0 THEN \'inst_only\'\n            WHEN used_inst = 0 AND used_pl = 1 THEN \'pl_only\'\n            ELSE \'unknown\'  -- always include ELSE\n        END AS segment\n    FROM user_products\n)\nSELECT\n    segment,\n    COUNT(DISTINCT user_id) AS user_count\nFROM segmented\nGROUP BY segment\nORDER BY user_count DESC;\n```\n\n---\n\n## 6. Partner-level breakdown\n\nFor \"metric by partner\" (CIMB vs CAKE vs TNEX vs ...).\n\n```sql\nSELECT\n    partner_code,\n    COUNT(DISTINCT user_id) AS active_users,\n    COUNT(*) AS txn_count,\n    SUM(amount) AS total_volume,\n    ROUND(AVG(amount), 0) AS avg_ticket\nFROM <transactions_table>\nWHERE created_at AT TIME ZONE \'asia/ho_chi_minh\'\n      >= DATEADD(month, -3, DATE_TRUNC(\'month\', GETDATE() AT TIME ZONE \'asia/ho_chi_minh\'))\n  AND status = \'SUCCESS\'\nGROUP BY partner_code\nORDER BY total_volume DESC;\n```\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('58d288eb-4d32-4673-9cb4-f14e18ca83a0','00000000-0000-0000-0000-000000000001','0365df0b-bc26-4abc-ae31-08df5d693e6c','reference/autoclose-gates.md','# Auto-close gates (Step 7 reference)\n\nRead this before calling `mark_done_cs_ticket`. **Default to LEAVE OPEN.** Auto-close requires ALL of Gate A clear AND ALL of Gate B holding. When any gate is ambiguous → leave open. A false-close (hidden customer issue) costs far more than a false-open (manual review later).\n\nCalibration: ~14%+ of bot-commented tickets historically still needed a human, and a PROD audit found 3 of 6 actual auto-closes were risky (deflection language, hedging, abandoned template). The dominant failure is mistaking an investigative comment for a resolution. See [casebook.md](casebook.md).\n\n## Gate A — Hard blockers (ANY one → LEAVE OPEN)\n\n- **A1. Action-item / deflection language** in CTA or Giải pháp: \"Cần kiểm tra/xác minh/làm rõ/điều tra\", \"Chuyển cho [team]\", \"Escalate\", \"Liên hệ đội/đối tác/team\", \"Kiểm tra logs/config\", \"Cần thông tin thêm\", \"Cần làm việc với\". **\"Liên hệ tổng đài đối tác để kiểm tra chi tiết\" counts as deflection** when the customer asked a question you did not answer.\n- **A2. Uncertainty hedging** in Nguyên nhân: \"có thể\", \"có lẽ\", \"khả năng\", \"ước chừng\", \"gợi ý\", \"chưa rõ\", \"chưa xác định\", \"tạm thời\", \"có vẻ\", \"không chắc\", \"khó xác định\".\n- **A3. KB lookup returned no usable match** for the class / error code (cannot cite a policy or decoded code that explains the behaviour).\n- **A4. Step 5 noted** any of: max enrichment rounds exhausted, missing critical data, contradictions, recommended escalation.\n- **A5. Partner ∉ {SHB, CAKE, TNEX}**, or partner-side investigation is still open.\n- **A6. A pending internal remediation** exists — dev fix in flight, data backfill needed, manual CS workaround, monitoring required. **A partner error code alone (TNEX 400, `response=null`) does NOT clear this gate.**\n- **A7. CTA does not answer the customer\'s explicit ask** (from Step 1). If KH asked \"why rejected\" and you only said \"không thoả mãn chính sách / liên hệ đối tác\" without a decoded reason → blocker.\n- **A8. Template or KB citation missing** — comment skipped the Nguyên nhân/CTA/DEBUG structure, OR a by-design/policy claim has no KB citation.\n- **A9. Partner attribution unverified** — `partner_code` was assumed without a `loan_application_id` record tying the user to that partner.\n\n## Gate B — Required positives (ALL must hold)\n\n- **B1.** Root cause stated definitively (no hedging).\n- **B2.** CTA is a **terminal action**: a complete self-serve explanation (incl. hotline if relevant), OR confirmation of correct system state, OR a by-design explanation WITH a KB citation, OR (for `self_recovered`) confirmation the loan reached terminal-success after the complaint.\n- **B3.** `Kết quả tra cứu` has concrete evidence: loan ID + status AND a **decoded** error-code→meaning (not a raw literal label), or a trace ID. Hypotheses do not count.\n- **B4.** No future verb in CTA (\"sẽ kiểm tra\", \"sẽ liên hệ\" = not done = leave open).\n- **B5.** The CTA answers the customer\'s explicit ask (positive mirror of A7).\n\n## Decision\n\n- **ALL Gate A clear AND ALL Gate B hold** → `mark_done_cs_ticket` with `issue_key` + `root_cause_type`:\n  - `communication` — bot delivered a self-contained explanation/instruction (covers `self_recovered`, `working_as_designed`, clear `user_misunderstanding`); no system fault to fix.\n  - `external_factors` — partner-side cause with **affirmative proof the partner owns the fix AND no internal action pending**. Do NOT use this merely because the JIRA resolution field says \"3rd Party\": every audited TNEX-400 \"3rd Party\" ticket still needed an internal fix (see casebook).\n- **Any blocker hits OR any positive missing** → do NOT call `mark_done_cs_ticket`.\n\nAfter auto-closing, tell the user:\n> Ticket [ID] đã chuyển Resolved (root_cause_type=`communication`). Label `auto_resolved` đã apply.\n\nIf leaving open, name the gate that failed:\n> Mình giữ ticket [ID] mở: CTA còn \"liên hệ tổng đài SHB để kiểm tra\" mà chưa giải mã được lý do từ chối (A1 + A7).\n','2026-06-17 04:44:03','2026-06-17 04:44:03');
INSERT INTO `skill_files` VALUES ('58e4e83f-50ae-4829-9c3a-17101bde3ac8','00000000-0000-0000-0000-000000000001','fbdd71f5-af17-4e67-b10d-b0a2b9601a32','chat-json-render-output/examples/weekly-disbursement-chart.json','{\n  \"root\": \"card\",\n  \"elements\": {\n    \"card\": {\n      \"type\": \"Card\",\n      \"props\": {\n        \"title\": \"Doanh số giải ngân Cash Loan - CAKE\",\n        \"description\": \"Biến động tổng tiền giải ngân (VND) theo tuần\"\n      },\n      \"children\": [\"chart\"]\n    },\n    \"chart\": {\n      \"type\": \"BarChart\",\n      \"props\": {\n        \"title\": \"Tổng tiền giải ngân (VND)\",\n        \"data\": [\n          {\n            \"label\": \"26/02\",\n            \"value\": 18504000000\n          },\n          {\n            \"label\": \"04/03\",\n            \"value\": 22450000000\n          },\n          {\n            \"label\": \"11/03\",\n            \"value\": 24800000000\n          },\n          {\n            \"label\": \"18/03\",\n            \"value\": 26550000000\n          },\n          {\n            \"label\": \"25/03\",\n            \"value\": 25100000000\n          },\n          {\n            \"label\": \"01/04\",\n            \"value\": 28950000000\n          },\n          {\n            \"label\": \"08/04\",\n            \"value\": 31200000000\n          },\n          {\n            \"label\": \"15/04\",\n            \"value\": 34500000000\n          },\n          {\n            \"label\": \"22/04\",\n            \"value\": 38150000000\n          },\n          {\n            \"label\": \"29/04\",\n            \"value\": 42500000000\n          }\n        ]\n      },\n      \"children\": []\n    }\n  }\n}\n','2026-06-17 04:43:47','2026-06-17 04:43:47');
INSERT INTO `skill_files` VALUES ('5d1e7dd9-9288-421b-a67f-8e0c08f401e2','00000000-0000-0000-0000-000000000001','fbdd71f5-af17-4e67-b10d-b0a2b9601a32','chat-json-render-output/references/component-catalog.md','# Component Catalog\n\nThis file is the reference for `chat-json-render-output`.\n\nThe cs-tool frontend renders `json-render` fences through Comark\'s JSON Render plugin and a local component map exported from `ReportRenderer.tsx`. Comark supports `json-render` and `yaml-render` fenced blocks, a full `{ \"root\", \"elements\" }` spec, and a single-element shorthand. The active cs-tool renderer also normalizes compact tree specs shaped like `{ \"component\", \"props\", \"children\" }`.\n\nThe cs-tool chat renderer also extracts fenced `chat-html`, `html-render`, and `render-html` blocks and renders them in a sandboxed iframe after sanitizing the fragment. Use this only when a bespoke data card or report layout is needed.\n\nOpen `ui/web/json-render-elements.html` in the Vite dev server to inspect every currently mapped component in one page.\n\nThe mapped visual language follows Refero\'s Family style reference: warm canvas (`#fbfaf9`), parchment cards (`#f8f7f4`), stone inset borders (`#f2f0ed`), graphite text (`#343433` / `#474645`), muted ash (`#848281`), and Ember Orange (`#ff3e00`) as the primary accent.\n\n## Chat HTML Renderer\n\nUse `chat-html` for self-contained HTML fragments only. Do not emit a full document, React code, JSX, scripts, forms, iframes, images, or remote assets.\n\nSupported tags include common text/layout/table tags: `section`, `article`, `aside`, `header`, `footer`, `div`, `span`, `p`, `small`, headings, `strong`, `em`, `b`, `i`, `code`, `pre`, `ul`, `ol`, `li`, `dl`, `dt`, `dd`, `table`, `thead`, `tbody`, `tr`, `th`, `td`, `hr`, `br`, `a`, and one scoped `style` tag.\n\nSupported attributes are intentionally limited: `class`, `id`, `role`, `style`, `title`, `aria-*`, `data-*`, and safe anchor `href` values (`https://`, `http://`, `mailto:`, `#`, `/`). Event handlers such as `onclick` are removed.\n\nCSS is sanitized. Do not use `@import`, `url(...)`, or `expression(...)`. Keep CSS scoped to the fragment classes and include responsive rules for mobile chat widths.\n\nGood `chat-html` use cases:\n\n- Loan trace cards with summary, metrics, timeline, and error detail.\n- Trade or transaction lifecycle cards with each state transition shown as a timeline.\n- Issue or ticket diagnosis cards with reproduce/check/fail/fix steps shown visually.\n- Compact KPI dashboards where exact visual grouping matters.\n- Investigation reports that need status dots, badges, and dense data tiles beyond the JSON Render component map.\n\nPrefer `json-render` when mapped components can express the answer with less custom layout.\n\nWhen a result includes steps over time, the HTML should make the sequence visible. Use a summary area, a compact facts grid, a chronological timeline, and a final callout for root cause, blocker, or next action.\n\n## Active cs-tool catalog\n\nUse these components. Unknown names render as fallback UI.\n\n### Stack\n\nFlex layout. Supports children.\n\nProps:\n\n- `direction`: `\"vertical\"` or `\"horizontal\"`, default `\"vertical\"`.\n- `gap`: `\"sm\"`, `\"md\"`, or `\"lg\"`, default `\"md\"`.\n\n### Grid\n\nResponsive grid. Supports children.\n\nProps:\n\n- `columns`: `\"2\"` or `\"3\"`, default `\"2\"`.\n\n### Card\n\nContent section. Supports children. Do not nest `Card` inside `Card`.\n\nProps:\n\n- `title`: string.\n- `description`: string.\n- `subTitle` and `subtitle` are accepted as aliases and normalized to `description`.\n\n### Heading\n\nHeading text.\n\nProps:\n\n- `text`: string.\n- `level`: `\"1\"`, `\"2\"`, or `\"3\"`, default `\"2\"`.\n\n### Text\n\nParagraph text.\n\nProps:\n\n- `content`: string.\n- `muted`: boolean.\n\n### Badge\n\nSmall status label.\n\nProps:\n\n- `label`: string.\n- `tone`: `\"neutral\"`, `\"success\"`, `\"warning\"`, or `\"error\"`, default `\"neutral\"`.\n\n### Callout\n\nRisk, note, warning, or error block.\n\nProps:\n\n- `title`: string.\n- `content`: string.\n- `tone`: `\"info\"`, `\"success\"`, `\"warning\"`, or `\"error\"`, default `\"info\"`.\n\n### Metric\n\nKPI/stat display.\n\nProps:\n\n- `label`: string.\n- `value`: string.\n- `detail`: string.\n\n### Steps\n\nOrdered status list.\n\nProps:\n\n- `items`: array of `{ \"title\": string, \"detail\": string, \"status\": \"done\" | \"active\" | \"pending\" | \"error\" }`.\n\n### FileChange\n\nSingle file-change row.\n\nProps:\n\n- `path`: string.\n- `kind`: `\"created\"`, `\"modified\"`, or `\"deleted\"`, default `\"modified\"`.\n- `summary`: string.\n- `additions`: number.\n- `deletions`: number.\n\n### CodeBlock\n\nCode snippet display.\n\nProps:\n\n- `code`: string.\n- `language`: string.\n- `title`: string.\n\n### Terminal\n\nCommand output display.\n\nProps:\n\n- `command`: string.\n- `output`: string.\n- `exitCode`: number.\n\n### TestResults\n\nTest summary display.\n\nProps:\n\n- `passed`: number.\n- `failed`: number.\n- `skipped`: number.\n- `failures`: array of `{ \"name\": string, \"message\": string }`.\n\n### Chart Data Basics\n\nMost chart wrappers accept a compact data shape:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string. Use `\"%\"` for percentages.\n\nThe renderer composes the underlying Bklit chart primitives internally, so JSON Render specs should not include raw chart child components such as `Line`, `PieSlice`, `SankeyNode`, or `ChartTooltip`.\n\nAccepted normalization aliases for simple chart specs:\n\n- `xAxis.dataKey` or `xAxisKey` selects the label key from raw data rows.\n- first `series[].dataKey` selects the numeric value key.\n- first `series[].name` becomes `title` when `title` is missing.\n\n### AreaChart\n\nFilled ordered trend chart using Bklit chart components.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string.\n\n### BarChart\n\nCategory bar chart using Bklit chart components.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string.\n\n### CandlestickChart\n\nOHLC chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"open\": number, \"high\": number, \"low\": number, \"close\": number }`.\n- `unit`: string.\n\nIf only `{ \"label\", \"value\" }` points are supplied, the renderer synthesizes simple OHLC rows from adjacent values.\n\n### ChoroplethChart\n\nGeoJSON feature map.\n\nProps:\n\n- `title`: string.\n- `data`: GeoJSON `FeatureCollection`.\n- `center`: `[longitude, latitude]`.\n- `scale`: number.\n- `zoomEnabled`: boolean.\n\nUse only when real GeoJSON is available. Otherwise use `Table`, `BarChart`, or `HeatmapChart`.\n\n### ComposedChart\n\nCombined bar and line summary for ordered data.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string.\n\n### FunnelChart\n\nStage drop-off chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number, \"displayValue\": string, \"color\": string }`.\n- `orientation`: `\"horizontal\"` or `\"vertical\"`, default `\"horizontal\"`.\n- `edges`: `\"curved\"` or `\"straight\"`, default `\"curved\"`.\n\n### Gauge / GaugeChart\n\nSingle bounded KPI.\n\nProps:\n\n- `title`: string.\n- `label`: string.\n- `value`: number. Treated as 0-100 unless `maxValue` is supplied.\n- `maxValue`: number.\n- `unit`: string.\n\n### HeatmapChart\n\nIntensity heatmap.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`, or native heatmap columns shaped like `{ \"bin\": number, \"bins\": [{ \"bin\": number, \"count\": number, \"date\": string }] }`.\n\n### LineChart\n\nOrdered trend chart using Bklit chart components.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string.\n\n### BarGraph / LineGraph\n\nAliases for `BarChart` and `LineChart`. They accept the same props and the same Recharts-like normalization aliases.\n\n### LiveLineChart\n\nAnimated live-style trend chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`.\n- `unit`: string.\n\n### PieChart\n\nPart-to-whole chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number, \"color\": string }`.\n- `unit`: string.\n- `donut`: boolean. Default true.\n\n### ProfitLossLine\n\nLine chart that colors positive and negative sections differently.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }`, where values may be positive or negative.\n- `unit`: string.\n\n### RadarChart\n\nMulti-metric score chart.\n\nProps:\n\n- Simple mode: `data` array of `{ \"label\": string, \"value\": number }`.\n- Native mode: `metrics` array of `{ \"key\": string, \"label\": string }` plus `data` rows shaped like `{ \"label\": string, \"values\": { [key]: number } }`. Values are normalized 0-100.\n\n### RingChart\n\nMulti-ring progress chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number, \"maxValue\": number, \"color\": string }`.\n- `unit`: string.\n\n### SankeyChart\n\nFlow chart.\n\nProps:\n\n- `title`: string.\n- `nodes`: array of `{ \"name\": string }`.\n- `links`: array of `{ \"source\": number, \"target\": number, \"value\": number }`.\n\nIf simple `{ \"label\", \"value\" }` points are supplied, the renderer can synthesize a sequential flow, but explicit nodes/links are preferred.\n\n### ScatterChart\n\nPoint distribution chart.\n\nProps:\n\n- `title`: string.\n- `data`: array of `{ \"label\": string, \"value\": number }` or `{ \"label\": string, \"x\": string, \"y\": number }`.\n- `unit`: string.\n\n### Legend\n\nStatic legend preview.\n\nProps:\n\n- `title`: string.\n- `items`: array of `{ \"label\": string, \"value\": number, \"color\": string }`.\n- `data`: accepted as a fallback array of `{ \"label\": string, \"value\": number, \"color\": string }`.\n\n## Mapped upstream JSON Render components\n\nThe renderer now maps the remaining upstream JSON Render / shadcn-style names as static, safe report previews. Use these when they improve scanability. Static controls do not submit data or execute actions.\n\n### Alert\n\nAlert block. Similar to `Callout`.\n\nProps:\n\n- `title` or `label`: string.\n- `content`, `description`, or `message`: string.\n- `tone`: `\"info\"`, `\"success\"`, `\"warning\"`, or `\"error\"`, default `\"info\"`.\n\n### Avatar\n\nIdentity row.\n\nProps:\n\n- `name`, `label`, or `alt`: string.\n- `fallback`: string.\n- `src`: image URL. Avoid remote URLs unless user-supplied/trusted.\n\n### Button / ButtonGroup / Toggle / ToggleGroup\n\nStatic control previews.\n\nProps:\n\n- `label`, `text`, or `children`: string for single controls.\n- `variant`: `\"default\"`, `\"primary\"`, `\"secondary\"`, `\"outline\"`, `\"ghost\"`, `\"link\"`, or `\"destructive\"`.\n- `items`: array of `{ \"label\": string, \"value\": string, \"selected\": boolean }` for groups.\n- `selected`, `value`, or `defaultValue`: selected group value.\n\n### Input / Textarea / Select / Checkbox / Radio / Switch / Slider\n\nRead-only form/control previews.\n\nProps:\n\n- `label` or `name`: string.\n- `value` or `defaultValue`: string/number.\n- `placeholder`: string.\n- `checked`, `selected`, or `on`: boolean for binary controls.\n- `options`: array of `{ \"label\": string, \"value\": string }` for `Select`.\n\n### Progress / Skeleton / Spinner / Rating\n\nFeedback previews.\n\nProps:\n\n- `Progress`: `label`, `value` from 0-100.\n- `Skeleton`: `lines` from 1-6.\n- `Spinner`: `label`.\n- `Rating`: `value` or `rating` from 0-5.\n\n### Table\n\nCompact table. Prefer this over markdown tables inside the UI block.\n\nProps:\n\n- `caption`: string.\n- `columns`: array of strings or `{ \"label\": string }`.\n- `rows`: array of arrays or objects.\n- `data`: array of objects when `rows` is not provided.\n\n### Accordion / Collapsible / Tabs\n\nStatic disclosure previews.\n\nProps:\n\n- `items`: array of `{ \"label\": string, \"content\": string, \"open\": boolean, \"active\": boolean }`.\n- `selected`, `value`, or `defaultValue`: selected item value for tabs/accordion.\n- children are rendered when no `items` are supplied.\n\n### Dialog / Drawer / Popover / Tooltip / DropdownMenu\n\nStatic overlay previews.\n\nProps:\n\n- `title`, `label`, or `trigger`: string.\n- `content`, `description`, or `message`: string.\n- `items`: array of `{ \"label\": string }` for `DropdownMenu`.\n\n### Carousel / Pagination\n\nStatic navigation previews.\n\nProps:\n\n- `Carousel.items`: array of `{ \"title\": string, \"content\": string }`.\n- `Pagination.currentPage` or `page`: number.\n- `Pagination.totalPages` or `pageCount`: number.\n\n### Separator / Icon / Image / Link\n\nSmall content primitives.\n\nProps:\n\n- `Separator.orientation`: `\"horizontal\"` or `\"vertical\"`.\n- `Icon.name`: one of common semantic names such as `success`, `warning`, `error`, `image`, `link`, `star`, `menu`; unknown names fall back to info.\n- `Image.src`, `Image.alt`, `Image.title`, `Image.label`. Avoid remote URLs unless user-supplied/trusted.\n- `Link.href` or `url`; `label`, `text`, or `title`.\n\n## Upstream JSON Render shadcn components\n\nJSON Render\'s upstream `@json-render/shadcn` package currently documents these pre-built shadcn/ui components. The cs-tool renderer maps the names below as safe static report components.\n\nLayout:\n\n- `Card`\n- `Stack`\n- `Grid`\n- `Separator`\n\nNavigation:\n\n- `Tabs`\n- `Accordion`\n- `Collapsible`\n- `Pagination`\n\nOverlay:\n\n- `Dialog`\n- `Drawer`\n- `Tooltip`\n- `Popover`\n- `DropdownMenu`\n\nContent:\n\n- `Heading`\n- `Text`\n- `Image`\n- `Avatar`\n- `Badge`\n- `Alert`\n- `Carousel`\n- `Table`\n\nFeedback:\n\n- `Progress`\n- `Skeleton`\n- `Spinner`\n\nInput:\n\n- `Button`\n- `Link`\n- `Input`\n- `Textarea`\n- `Select`\n- `Checkbox`\n- `Radio`\n- `Switch`\n- `Slider`\n- `Toggle`\n- `ToggleGroup`\n- `ButtonGroup`\n\nThe public JSON Render playground also shows a broader demo catalog with graph and icon components such as `BarGraph`, `LineGraph`, `Icon`, and `Rating`; these are mapped in cs-tool.\n\n## Sources checked\n\n- https://comark.dev/plugins/built-in/json-render\n- https://json-render.dev/\n- https://json-render.dev/docs/api/shadcn\n- https://github.com/vercel-labs/json-render/blob/main/skills/shadcn/SKILL.md\n- https://styles.refero.design/style/1bcae895-2245-4d33-aa43-1c1e80719554\n- https://bklit.com/docs/components\n','2026-06-17 04:43:47','2026-06-17 04:43:47');
INSERT INTO `skill_files` VALUES ('5d91c4a1-8b70-4fcb-8c8f-792bf995b3b4','cf004684-86a3-48d1-b09e-32a6c6e7de3a','3dfd791a-9cdb-433f-be5d-df06d14d1c42','docs/metabase_cheat_sheet.md','# Metabase Syntax Cheat Sheet\n\n## Basic Variables\nUsed for simple text, number, or date inputs.','2026-06-10 05:33:51','2026-06-10 05:33:51');
INSERT INTO `skill_files` VALUES ('634be4d4-1c99-4d57-9778-f53ba3965922','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/cashloan-samples/field_description.csv','column_name,data_type,null_allowed,default_value,description\nid,BIGINT,YES,AUTO_INCREMENT,\"Primary key, unique identifier for each record\"\nloan_application_id,VARCHAR(50),YES,-,Reference to loan application from onboarding module\nzalopay_id,VARCHAR(50),YES,-,ZaloPay user identifier\npartner_code,VARCHAR(50),YES,-,\"Partner bank code: SHB, CAKE, LFVN\"\noutstanding_amount,BIGINT,YES,-,Remaining principal amount to be repaid in VND\noverdue_amount,BIGINT,YES,-,Amount that is past due in VND\npartner_contract_number,VARCHAR(50),YES,,Contract number from partner bank\nloan_amount,BIGINT,YES,-,Original loan amount in VND\nloan_term,VARCHAR(10),YES,-,\"Loan term (e.g. 3M, 6M, 12M)\"\nuser_profile,JSON,YES,-,User profile information copied from loan application\nuser_info,JSON,YES,-,User additional information copied from loan application\nloan_info,JSON,YES,-,\"Loan details including interest rates, fees, etc.\"\npartner_data,JSON,YES,-,Partner-specific loan data and payment details\ncreated_at,DATETIME,YES,CURRENT_TIMESTAMP,Record creation timestamp\nupdated_at,DATETIME,YES,CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,Record last update timestamp\nstatus,INT,YES,1,\"Loan status: 1=ACTIVE, 2=SETTLED\"\nsettled_at,DATETIME,NO,NULL,Timestamp when loan was fully repaid\ncontract_id,VARCHAR(64),NO,NULL,Additional contract identifier from partner\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('7517a954-e382-433c-ab08-e863b007e6f6','00000000-0000-0000-0000-000000000001','fbdd71f5-af17-4e67-b10d-b0a2b9601a32','chat-json-render-output/examples/cs-investigation-report.json','{\n  \"root\": \"report\",\n  \"elements\": {\n    \"report\": {\n      \"type\": \"Stack\",\n      \"props\": {\n        \"direction\": \"vertical\",\n        \"gap\": \"md\"\n      },\n      \"children\": [\"summary\", \"metrics\", \"checks\", \"risk\"]\n    },\n    \"summary\": {\n      \"type\": \"Card\",\n      \"props\": {\n        \"title\": \"Tóm tắt xử lý\",\n        \"description\": \"Chưa đủ dữ liệu để xác định root cause. Cần kiểm tra log OTP phía đối tác.\"\n      },\n      \"children\": [\"status\"]\n    },\n    \"status\": {\n      \"type\": \"Badge\",\n      \"props\": {\n        \"label\": \"Cần điều tra thêm\",\n        \"tone\": \"warning\"\n      },\n      \"children\": []\n    },\n    \"metrics\": {\n      \"type\": \"Grid\",\n      \"props\": {\n        \"columns\": \"3\"\n      },\n      \"children\": [\"loan-records\", \"http-errors\", \"owner\"]\n    },\n    \"loan-records\": {\n      \"type\": \"Metric\",\n      \"props\": {\n        \"label\": \"Loan records\",\n        \"value\": \"0\",\n        \"detail\": \"Không tìm thấy theo UserID\"\n      },\n      \"children\": []\n    },\n    \"http-errors\": {\n      \"type\": \"Metric\",\n      \"props\": {\n        \"label\": \"HTTP errors\",\n        \"value\": \"0\",\n        \"detail\": \"Trong khoảng thời gian kiểm tra\"\n      },\n      \"children\": []\n    },\n    \"owner\": {\n      \"type\": \"Metric\",\n      \"props\": {\n        \"label\": \"Owner kế tiếp\",\n        \"value\": \"Partner\",\n        \"detail\": \"Cần đối soát log OTP/client\"\n      },\n      \"children\": []\n    },\n    \"checks\": {\n      \"type\": \"Steps\",\n      \"props\": {\n        \"items\": [\n          {\n            \"title\": \"Tra cứu hồ sơ vay\",\n            \"detail\": \"Không tìm thấy record liên quan.\",\n            \"status\": \"done\"\n          },\n          {\n            \"title\": \"Kiểm tra log lỗi\",\n            \"detail\": \"Chưa thấy lỗi backend ZaloPay.\",\n            \"status\": \"done\"\n          },\n          {\n            \"title\": \"Đối soát log OTP đối tác\",\n            \"detail\": \"Cần dữ liệu từ đối tác.\",\n            \"status\": \"pending\"\n          }\n        ]\n      },\n      \"children\": []\n    },\n    \"risk\": {\n      \"type\": \"Callout\",\n      \"props\": {\n        \"title\": \"Chưa kết luận root cause\",\n        \"content\": \"Không có bằng chứng backend đủ mạnh; tránh chốt nguyên nhân trước khi có log OTP phía đối tác.\",\n        \"tone\": \"warning\"\n      },\n      \"children\": []\n    }\n  }\n}\n','2026-06-17 04:43:47','2026-06-17 04:43:47');
INSERT INTO `skill_files` VALUES ('9f72b479-8c2c-4247-933b-026da66047be','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/cashloan-samples/datawarehouse_cashloan_active_loans_mart.csv','table_name,column_name,data_type\ncashloan_active_loans_mart,id,bigint\ncashloan_active_loans_mart,loan_application_id,character varying\ncashloan_active_loans_mart,user_id,character varying\ncashloan_active_loans_mart,partner_code,character varying\ncashloan_active_loans_mart,outstanding_amount,bigint\ncashloan_active_loans_mart,overdue_amount,bigint\ncashloan_active_loans_mart,partner_contract_number,character varying\ncashloan_active_loans_mart,loan_amount,bigint\ncashloan_active_loans_mart,loan_term,character varying\ncashloan_active_loans_mart,loan_info,super\ncashloan_active_loans_mart,partner_data,super\ncashloan_active_loans_mart,create_at,timestamp with time zone\ncashloan_active_loans_mart,update_at,timestamp with time zone\ncashloan_active_loans_mart,settle_at,timestamp with time zone\ncashloan_active_loans_mart,status,integer\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('b0f6b07f-2c29-4120-b14b-f843a322d370','00000000-0000-0000-0000-000000000001','0365df0b-bc26-4abc-ae31-08df5d693e6c','reference/investigation.md','# Investigation reference\n\nHow to investigate a Cashloan CS ticket once it is parsed and classified (Step 4 of SKILL.md). Always analyze the **newest loan application first**.\n\n## Contents\n- Tool selection by available data\n- Mandatory error-code decoding\n- Don\'t trust the reporter\'s window\n- `response=null` / enrichment failures\n- Drilling OpenSearch results (trace drill-down)\n\n## Tool selection by available data\n\n| Condition | Action |\n|-----------|--------|\n| Have `loan_application_id` | `get_loan_detail` |\n| Have `zalopay_id` only | `get_customer_loans` → `get_loan_detail` on most recent |\n| Have `zalopay_id` + `event_time` | `search_http_errors` (delta ~2-3 days); if error → drill by `trace_id` |\n| Found `trace_id` in logs | `get_logs_by_trace_id` (max 2-3 traces) |\n| Partner submission failed (\"submit hồ sơ lỗi\") | `get_activity_log` with `loan_application_id` |\n| Wrong/missing data on app from a known API | `get_api_info` with `method` + `user_id` (supported: `GetActiveLoan`) |\n| Need process/policy/error-code meaning | `search_knowledge` |\n\n`get_activity_log` is keyed by **loan application**; `search_http_errors` by **user**. Use `get_api_info` only when you can map the symptom to a specific supported method — do NOT guess the method.\n\n## Mandatory error-code decoding\n\nWhen any partner or internal error code/message appears (`-18`, `-23`, `-32`, `StepCode invalid`, `Trạng thái hợp đồng không hợp lệ`, `bad_request`, `response=null`, …):\n\n1. `search_knowledge` for the code\'s real meaning. Do NOT translate the English label literally.\n2. Decoded → state the decoded meaning as the root cause.\n3. Not in KB → say explicitly \"code `X` chưa có trong KB, chưa giải mã được\" and LEAVE the ticket OPEN. Never guess.\n\nReal misses this prevents:\n- `-18` read literally as an \"image bug\" was actually a CMND→CCCD identity-document mismatch at CAKE.\n- `StepCode invalid` / `Trạng thái hợp đồng không hợp lệ` at the OTP stage was an **expired signing window** → re-apply, not a code defect.\n\n## Don\'t trust the reporter\'s window\n\nIf `search_http_errors` at the reported `event_time` returns nothing, widen `hours_delta` ONCE and **pivot to the loan\'s own state history** (the cancel/reject/fail events on the newest loans). The real incident is often on a different day than CS wrote. Do NOT conclude \"probably fixed, ask user to re-test\" from an empty window (this produced an Unresolved miss — ISSUE-38625).\n\nLikewise, do not trust a reported channel label (\"gửi Noti\") — verify the actual surface before asserting it (ISSUE-40087: real surface was home-screen entry points, not push notifications).\n\n## `response=null` / enrichment failures\n\n`response=null` or `400 Invalid Request` on enrichment calls (`GetActiveLoan`, `GetOutstandingBalance`) is a recurring **internal data-completeness bug**, not a partner outage. Classify `technical_error` (internal) and leave open — these needed a dev data-backfill before the customer could retry (ISSUE-38894 / 38808 / 38474).\n\n## Drilling OpenSearch results\n\n`search_http_errors`, `get_activity_log`, `get_api_info` return `trace_id` / `span_id`. When a result is suspicious or partial, follow up with `get_logs_by_trace_id` to reconstruct the end-to-end cross-service trace.\n\n- Pick at most 2-3 representative `trace_id`s (newest, or the clearest error).\n- Center on the hit\'s `event_time` with the same default `hours_delta`.\n- Stop once root cause is clear; more traces are usually redundant.\n','2026-06-17 04:44:03','2026-06-17 04:44:03');
INSERT INTO `skill_files` VALUES ('b20216b6-b632-473f-acb6-de3847fb13fb','f1eab81b-eedc-455d-8b19-dccdd3d0754e','3dafd1ef-bc7a-4b9e-bd0d-ddd172075140','rules/openapi_rules.json','{\n  \"api_guidelines\": {\n    \"casing\": {\n      \"paths\": \"kebab-case\",\n      \"query_parameters\": \"snake_case\",\n      \"headers\": \"Train-Case\"\n    },\n    \"responses\": {\n      \"require_standard_error_schema\": true,\n      \"standard_error_schema_ref\": \"#/components/schemas/StandardError\",\n      \"required_status_codes\": [\"400\", \"401\", \"403\", \"404\", \"500\"]\n    },\n    \"security\": {\n      \"require_global_security\": false,\n      \"required_headers\": [\n        \"X-Correlation-ID\"\n      ]\n    },\n    \"metadata\": {\n      \"require_description\": true,\n      \"require_contact_info\": true\n    }\n  }\n}','2026-06-09 17:46:12','2026-06-09 17:46:12');
INSERT INTO `skill_files` VALUES ('d5fbc3b3-ed58-479e-a7b1-d64665fc93ec','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/schema-cashloan.md','# Schema: Cash Loan\n\nTables in the `datawarehouse` schema covering ZaloPay\'s Cash Loan (multi-partner waterfall lending) product.\n\n## Table of contents\n\n1. [`datawarehouse.cashloan_active_loans_mart`](#datawarehousecashloan_active_loans_mart) — The active + settled loan book: one row per *version* of a disbursed loan. Principal, outstanding, overdue, term, loan economics (`loan_info` SUPER), and partner-specific workflow/balance data (`partner_data` SUPER). Partners: CAKE, SHB, TNEX (others may appear).\n\n## Cross-table / cross-domain notes\n\n- **`user_id`** is the ZaloPay user ID (varchar) — the join key to BNPL tables (`paylater_*`) and shared user tables. Use it for any \"BNPL users who also took a Cash Loan\" cross-domain question (load `schema-bnpl.md` too).\n- **`loan_application_id`** links a disbursed loan back to its onboarding application (format `YYYYMMDD-<uuid>`). The application/onboarding funnel itself lives upstream (not in this mart).\n- **Always ask which partner** before generating SQL if the user hasn\'t specified one — partner economics and the shape of `partner_data` differ enormously (see below). Don\'t default to all-partners-blended. See the \"Always ask: which partner?\" rule in `SKILL.md`.\n\n---\n\n## `datawarehouse.cashloan_active_loans_mart`\n\n**Description:** The Cash Loan book — every loan that has been disbursed through ZaloPay\'s multi-partner (waterfall) routing. Despite the name \"active_loans\", the table also retains **settled** loans (`status = 2`), so it is the primary table for outstanding balance, arrears/overdue monitoring, disbursement volume, and loan-economics analysis across partners.\n\n**Grain:** One row per *version* of a loan. **Not** one row per loan — this is an append-only mart (see \"Critical: row uniqueness\" below).\n\n### Columns\n\nThe schema export you may have seen lists only the 15 \"business\" columns. The table as materialized in the warehouse also carries the four standard mart columns (`mart_skey`, `user_skey`, `sys_effective_date`, `sys_create_date`), exactly like the `paylater_*` marts. Full column list:\n\n| Column | Type | Description |\n|---|---|---|\n| `mart_skey` | `bigint` | Surrogate key of the data mart record. **Unique per row** — the only true row-level unique key. |\n| `id` | `bigint` | Identifier of the loan. **Append-only business key** — the same `id` appears across multiple rows as the loan updates. Dedupe with `ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC)`. |\n| `loan_application_id` | `varchar` | Reference to the loan application from the onboarding module. Format `YYYYMMDD-<uuid>` (e.g. `20260531-ab50e2d8-...`). |\n| `user_skey` | `bigint` | Internal surrogate key for the user. **NULL in samples** — prefer `user_id` for joins until confirmed populated. |\n| `user_id` | `varchar` | ZaloPay user ID. The cross-table join key (matches `paylater_*` tables and shared user tables). (Some source docs call this `zalopay_id` — same thing; the warehouse column is `user_id`.) |\n| `partner_code` | `varchar` | Lending partner. **Values seen in data: `\'CAKE\'`, `\'SHB\'`, `\'TNEX\'`.** Other partners (e.g. `\'LFVN\'`, `\'VietCredit\'`, `\'VPB\'`) may appear as the waterfall expands — confirm against live data before filtering on a partner not listed here. |\n| `outstanding_amount` | `bigint` | Remaining principal to be repaid, in VND. **Authoritative outstanding figure for SHB and TNEX** (their `partner_data` carries no balance detail). For a fresh, unpaid loan this equals `loan_amount`. |\n| `overdue_amount` | `bigint` | Amount currently past due, in VND. **`0` = current / not delinquent.** `> 0` = in arrears. Primary delinquency field for SHB and TNEX. |\n| `partner_contract_number` | `varchar` | Contract number at the partner bank. Format is **partner-specific** (CAKE: alphanumeric token; SHB: long numeric; TNEX: dotted numeric `0101.02.xxxxxxxxxx`). Don\'t assume a common format. |\n| `loan_amount` | `bigint` | Disbursed loan principal, in VND. This is the **approved/disbursed** amount, which may be **smaller than what the user requested** — the requested figure lives in `loan_info.LoanAmount` (see SUPER section). |\n| `loan_term` | `varchar` | Loan term **in months, as a bare number string** — e.g. `\'7\'`, `\'9\'`, `\'18\'`. **NOT** the `\'3M\'/\'6M\'/\'12M\'` format some docs suggest. Cast with `loan_term::int` for numeric comparison. |\n| `loan_info` | `super` | Loan economics + a snapshot of the application/scoring context. **Redshift SUPER type**, not a varchar JSON string — access with path notation, not `JSON_EXTRACT_PATH_TEXT`. Sub-fields documented below. Reasonably consistent across partners. |\n| `partner_data` | `super` | Partner-specific loan + workflow data. **Redshift SUPER type.** **There is NO common schema across partners** — the shape differs completely between CAKE, SHB, and TNEX. See the partner-specific breakdown below. This is the single biggest gotcha on this table. |\n| `create_at` | `timestamp with time zone` | When the loan record was created (effectively disbursement time). UTC-stored — convert with `AT TIME ZONE \'asia/ho_chi_minh\'`. Note the name is `create_at`, **not** `create_time`. |\n| `update_at` | `timestamp with time zone` | When the row was last updated in the source system. **This is the append-only dedup ordering column** — order by `update_at DESC` (the global rule\'s `update_time` is named `update_at` on this table). |\n| `sys_effective_date` | `timestamp with time zone` | Warehouse-side effective date. **Do not use for picking the latest version** — use `update_at`. |\n| `sys_create_date` | `timestamp with time zone` | When the row was inserted into the warehouse. |\n| `settle_at` | `timestamp with time zone` | When the loan was fully repaid. **NULL while the loan is active** (`status = 1`); populated when `status = 2`. |\n| `status` | `integer` | Loan status. **`1` = ACTIVE, `2` = SETTLED.** Use `status = 1` for the live loan book; `status = 2` for repaid loans. |\n\n### `status` reference (use frequently)\n\n| `status` | Meaning | When to use |\n|---|---|---|\n| `1` | ACTIVE — loan is live, being repaid | Outstanding book, arrears monitoring, active-loan counts |\n| `2` | SETTLED — loan fully repaid (`settle_at` populated) | Repaid-loan analysis, time-to-settle, completed-loan economics |\n\n### Mandatory filters\n\nApply this unless the user explicitly overrides:\n\n- **For disbursement/cohort analysis** (volume, new loans by month): date-filter on `create_at` — last 3 months by default per the global SQL conventions.\n- **For current-state balance / arrears snapshots:** this is a loan-book mart, so you usually want **all active loans regardless of disbursement date** — **drop the `create_at` window** and filter on `status = 1` instead. Adding a 3-month `create_at` filter will silently exclude loans disbursed earlier that are still outstanding. (Same principle as `paylater_account_mart_real` in `schema-bnpl.md`.)\n\n### Critical: row uniqueness (append-only)\n\nThis table follows the standard append-only pattern (see \"Append-only tables\" in `SKILL.md`). The business ID is **`id`** (the loan ID); `mart_skey` is the row-level unique key.\n\n`id` is **NOT unique**. As a loan updates (balance sync, status change, settlement), a new row is inserted with the same `id` and a later `update_at`. The same `id` can appear many times.\n\n**The dedup ordering column on this table is `update_at`** (not `update_time`, not `sys_effective_date`). Apply the standard dedup CTE before any `SUM`, `COUNT(DISTINCT id)`, or loan-level analysis:\n\n```sql\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n        WHERE create_at AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT * FROM latest_loan;\n```\n\n(For current-state balance snapshots, drop the `create_at` filter inside the subquery and add `WHERE status = 1` in the outer query — see \"Mandatory filters\" above.)\n\n---\n\n## SUPER columns — `loan_info` and `partner_data`\n\nBoth are Redshift **`super`** type (semi-structured), **not** varchar JSON. This changes how you read them:\n\n- **Access with path notation**, e.g. `li.loan_info.ApprovedAmount`, **not** `JSON_EXTRACT_PATH_TEXT(...)` (that function is for varchar JSON strings like BNPL\'s `extra`).\n- **Cast the extracted value** to a concrete type for math or display: `loan_info.ApprovedAmount::bigint`, `loan_info.MonthlyInterest::decimal(10,2)`, `partner_data.loan_detail.day_arrears::int`. Numbers stored as quoted strings inside the JSON (common in `partner_data.loan_detail`, e.g. `\"12000000\"`) still cast cleanly with `::bigint`.\n- **Keys are mixed-case and case-sensitive in SUPER navigation.** `loan_info` uses PascalCase keys (`ApprovedAmount`, `ZaloPayScore`); CAKE/TNEX `partner_data` use snake_case; SHB `partner_data` uses PascalCase. By default Redshift navigates SUPER **case-insensitively**, so a mixed-case key like `ApprovedAmount` won\'t resolve. Turn on case-sensitive SUPER navigation once at the top of the query and reference the keys **unquoted, with their exact casing** (`loan_info.ApprovedAmount`):\n  ```sql\n  SET enable_case_sensitive_super_attribute TO true;\n  ```\n  Use this rather than `enable_case_sensitive_identifier` — the SUPER-scoped setting only affects SUPER columns and won\'t make your other column names/aliases case-sensitive. Do **not** wrap the SUPER key in double quotes under this setting: a quoted mixed-case key can fold to lowercase and silently fail to match. (snake_case / all-lowercase keys like `partner_data.loan_detail.day_arrears` resolve either way.)\n- **To unnest arrays** (e.g. TNEX `partner_data.events`, the `full_status` arrays), use Redshift PartiQL iteration:\n  ```sql\n  SELECT l.id, e.event_status::varchar AS event_status, e.event_time::varchar AS event_time\n  FROM latest_loan l, l.partner_data.events AS e\n  WHERE l.partner_code = \'TNEX\';\n  ```\n\n### `loan_info` sub-fields (reasonably consistent across partners)\n\nTop-level fields inside the `loan_info` SUPER object:\n\n| Path | Type | Description |\n|---|---|---|\n| `loan_info.Partner` | `varchar` | Partner name — mirrors `partner_code`. |\n| `loan_info.ProductCode` | `varchar` | Partner product code. Known values: `\'ZLPCL01\'` (CAKE), `\'ZALOPAY_MASS\'` (SHB), `\'TNEXCL01\'` (TNEX). |\n| `loan_info.ProductLine` | `int` | Product line indicator (`0` in samples). |\n| `loan_info.LoanAmount` | `bigint` | Amount the user **requested**. **Can exceed the disbursed `loan_amount` / `ApprovedAmount`** (e.g. CAKE sample requested 25M, approved 12M). Use this vs `ApprovedAmount` for approval-haircut analysis. |\n| `loan_info.ApprovedAmount` | `bigint` | Approved principal (matches root `loan_amount`). |\n| `loan_info.LoanTerm` | `varchar` | Requested term in months (string). |\n| `loan_info.ApprovedTerm` | `varchar` | Approved term in months (string; matches root `loan_term`). |\n| `loan_info.Interest` | `number` | Nominal annual interest rate (%, e.g. `55`). |\n| `loan_info.ApprovedInterest` | `number` | Approved annual interest rate (%) — may differ from `Interest` (e.g. TNEX `Interest` 50 vs `ApprovedInterest` 53). |\n| `loan_info.MonthlyInterest` | `varchar` | Monthly interest rate as a string (e.g. `\"4.58\"`). |\n| `loan_info.TotalAmount` | `bigint` | Total repayable over the loan (principal + interest + fees), VND. |\n| `loan_info.TotalInterestAmount` | `bigint` | Total interest over the loan, VND. |\n| `loan_info.MonthlyRepaymentAmount` | `bigint` | Scheduled monthly repayment, VND. |\n| `loan_info.LoanFee` | `bigint` | Loan/origination fee, VND (`0` in samples). |\n| `loan_info.CollectionFee` | `bigint` | Collection fee, VND. Populated for SHB (`108000` in sample); `0` for CAKE/TNEX. |\n| `loan_info.InsuranceFee` | `bigint` | Insurance fee, VND. Populated for TNEX (`360000`); `0` for CAKE/SHB. |\n| `loan_info.ApprovedInsuranceFee` | `bigint` | Approved insurance fee, VND. |\n| `loan_info.InsurancePartner` | `varchar` | Insurance provider (e.g. `\'VASS\'` for TNEX); `NULL` for CAKE/SHB. |\n| `loan_info.InsuranceRegistered` | `boolean` | Whether the user took insurance. `true` for the TNEX sample. |\n| `loan_info.StartPayDate` | `varchar` | First repayment date (date string, e.g. `\'2026-07-01\'`). |\n| `loan_info.ZaloPayScore` | `varchar` | Internal ZaloPay risk score as a string. **Real score for some partners (SHB `\"922\"`), placeholder `\"1\"` for others (CAKE/TNEX) where ZLP scoring wasn\'t the gating model.** Don\'t treat `\"1\"` as a real score. |\n| `loan_info.ScoreBand` | `varchar` | Score band label (e.g. `\'02. High\'`, or `\'no_data\'`). |\n| `loan_info.ConsentData` | `object` | `{\"sso\": bool, \"consent_content\": varchar}` — consent text shown at registration (may be empty string). |\n| `loan_info.FirstCheck` | `object` | Scoring + device snapshot at application time. Key sub-fields: `Score` (int), `ScoreBand`, `UserSegment`, `UserSegments` (array), `ScoreMonth`, `ScoreVersion`, plus device context (`DeviceID`, `DeviceOs`, `DeviceModel`, `Platform`, `AppVersion`, `UserIP`, `UserAgent`). |\n| `loan_info.FinalCheck` | `object` | Same shape as `FirstCheck`. **Empty / zeroed in active samples** — typically only populated at a later check stage. |\n\n### `partner_data` — partner-specific, NO common schema\n\n**Read this before touching `partner_data`.** The object shape is entirely different per partner. Pick the structure for the partner you filtered on; do not write a single path expecting it to work across partners.\n\n**CAKE** — snake_case; live balances live in a nested `loan_detail` object:\n\n| Path | Type | Description |\n|---|---|---|\n| `partner_data.full_status` | `array` | Workflow states reached, e.g. `[\"EKYC_SUCCESS\",\"LOAN_REVIEWING\",\"LOAN_APPROVE\",\"LOAN_ACTIVE\"]`. |\n| `partner_data.loan_detail.principle_balance` | `string→bigint` | Remaining principal (partner\'s figure). |\n| `partner_data.loan_detail.interest_balance` | `string→bigint` | Outstanding interest. |\n| `partner_data.loan_detail.penalty_principal_balance` | `string→bigint` | Overdue principal penalty balance. |\n| `partner_data.loan_detail.penalty_interest_balance` | `string→bigint` | Overdue interest penalty balance. |\n| `partner_data.loan_detail.day_arrears` | `string→int` | **Days past due (CAKE\'s DPD field).** `\'0\'` = current. |\n| `partner_data.loan_detail.paid_amount` | `string→bigint` | Amount repaid so far. |\n| `partner_data.loan_detail.prepayment_amount` | `string→bigint` | Prepaid amount. |\n| `partner_data.loan_detail.monthly_payment_amount` | `string→bigint` | Scheduled monthly payment. |\n| `partner_data.loan_detail.total_payment_amount` | `string→bigint` | Total repaid to date. |\n| `partner_data.loan_detail.due_date` | `string` | Next due date. |\n| `partner_data.loan_detail.disburse_date` | `string` | Disbursement date. |\n| `partner_data.loan_detail.disburse_amount` | `string→bigint` | Disbursed amount. |\n| `partner_data.loan_detail.approved_amount` | `string→bigint` | Approved principal. |\n| `partner_data.loan_detail.approved_term` | `string→int` | Approved term (months). |\n| `partner_data.loan_detail.interest_rate` | `string→number` | Interest rate (%). |\n| `partner_data.loan_detail.payment_period` | `string→int` | Current payment period index. |\n| `partner_data.loan_detail.loan_account_status` | `string` | Partner loan status, e.g. `\'LOAN_ACTIVE\'`. |\n\n**SHB** — PascalCase; **no per-loan balance detail** (use root `outstanding_amount` / `overdue_amount` for balances):\n\n| Path | Type | Description |\n|---|---|---|\n| `partner_data.StepCode` | `varchar` | Workflow step, e.g. `\'DONE\'`. |\n| `partner_data.ResponseCode` | `varchar` | Latest response code, e.g. `\'DISBURSEMENT\'`. |\n| `partner_data.BillCode` | `varchar` | Partner bill/loan reference. |\n| `partner_data.AppCode` | `varchar` | Partner application code. |\n| `partner_data.TransactionId` | `varchar` | Partner transaction ID. |\n| `partner_data.LeadId` | `varchar` | Lead ID (matches `loan_application_id`). |\n| `partner_data.LoanAmount` | `bigint` | Requested amount. |\n| `partner_data.ApprovedAmount` | `bigint` | Approved amount. |\n| `partner_data.ApprovedTerm` | `varchar` | Approved term (months). |\n| `partner_data.SubmittedTime` | `bigint` | Submission time, **epoch milliseconds**. |\n| `partner_data.ApprovalTime` | `bigint` | Approval time, epoch ms (`0` if not set). |\n| `partner_data.DisbursementTime` | `bigint` | Disbursement time, epoch ms (`0` if not set). |\n| `partner_data.DocumentFileDatas` | `varchar` | **Escaped JSON string** (not a parsed SUPER array) listing eKYC document upload results. Parse separately if needed. |\n\n**TNEX** — snake_case; lifecycle captured as an `events` array; **no `loan_detail`** (use root `outstanding_amount` / `overdue_amount`):\n\n| Path | Type | Description |\n|---|---|---|\n| `partner_data.full_status` | `array` | Workflow states, e.g. `[\"AUTHENTICATE\",\"FORSIGN\",\"FOR_DISBURSEMENT\",\"CLOSED\"]`. |\n| `partner_data.status` | `varchar` | Latest workflow status, e.g. `\'CLOSED\'`. |\n| `partner_data.registration_id` | `varchar` | TNEX registration ID. |\n| `partner_data.address_origin` | `varchar` | Source of address data, e.g. `\'NFC\'`. |\n| `partner_data.is_enrich_telco_score` | `boolean` | Whether telco-score enrichment ran. |\n| `partner_data.contract_info.contract_no` | `varchar` | Signed contract number (matches `partner_contract_number`). |\n| `partner_data.contract_info.signed_time` | `varchar` | Contract signing timestamp. |\n| `partner_data.contract_info.status` | `varchar` | Contract status, e.g. `\'SIGNED\'`. |\n| `partner_data.contract_info.signed_contract_file` | `varchar` | URL of signed contract PDF. |\n| `partner_data.ekyc_images` | `object` | eKYC image metadata keyed by doc type (`PORTRAIT`, `NFC`, `IDENTITY_CARD_FRONT`, `IDENTITY_CARD_BACK`), each with `path`, `content_type`, `checksum`. |\n| `partner_data.events` | `array` | Callback lifecycle events. Each element: `event_status`, `event_time`, `event_type`, `loan_amount`, `loan_approved_amount`, `product_id`, `referral_code`, `loan_id`. Unnest with PartiQL (see SUPER section). |\n\n---\n\n## Common queries\n\n**Active loan book by partner — current snapshot (deduped, `status = 1`):**\n\n```sql\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n    )\n    WHERE rn = 1\n)\nSELECT\n    partner_code,\n    COUNT(DISTINCT id)                                                AS active_loans,\n    COUNT(DISTINCT user_id)                                           AS borrowers,\n    SUM(loan_amount)                                                  AS disbursed_principal_vnd,\n    SUM(outstanding_amount)                                           AS outstanding_vnd,\n    SUM(overdue_amount)                                               AS overdue_vnd,\n    ROUND(100.0 * COUNT(DISTINCT CASE WHEN overdue_amount > 0 THEN id END)\n                / NULLIF(COUNT(DISTINCT id), 0), 2)                   AS overdue_loan_pct\nFROM latest_loan\nWHERE status = 1\nGROUP BY partner_code\nORDER BY outstanding_vnd DESC;\n```\n\n**Arrears / overdue bucket distribution by partner (current snapshot):**\n\n```sql\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n    )\n    WHERE rn = 1\n)\nSELECT\n    partner_code,\n    CASE\n        WHEN overdue_amount = 0                       THEN \'0 - current\'\n        WHEN overdue_amount BETWEEN 1 AND 1000000     THEN \'1 - 1M\'\n        WHEN overdue_amount BETWEEN 1000001 AND 5000000 THEN \'1M - 5M\'\n        WHEN overdue_amount > 5000000                 THEN \'5M+\'\n        ELSE \'unknown\'\n    END                                        AS overdue_bucket,\n    COUNT(DISTINCT id)                         AS loan_count,\n    COUNT(DISTINCT user_id)                    AS borrower_count,\n    SUM(overdue_amount)                        AS overdue_vnd\nFROM latest_loan\nWHERE status = 1\nGROUP BY partner_code, overdue_bucket\nORDER BY partner_code, overdue_bucket;\n```\n\n**New disbursements by month (cohort on `create_at`, deduped):**\n\n```sql\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n        WHERE create_at AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT\n    DATE_TRUNC(\'month\', create_at AT TIME ZONE \'asia/ho_chi_minh\') AS disburse_month,\n    partner_code,\n    COUNT(DISTINCT id)                                             AS loans_disbursed,\n    COUNT(DISTINCT user_id)                                        AS borrowers,\n    SUM(loan_amount)                                               AS disbursed_principal_vnd,\n    ROUND(AVG(loan_term::int), 1)                                 AS avg_term_months\nFROM latest_loan\nGROUP BY 1, 2\nORDER BY 1, 2;\n```\n\n**Loan economics from `loan_info` SUPER (approved amount, term, rate, monthly repayment) for one partner:**\n\n```sql\nSET enable_case_sensitive_super_attribute TO true;\n\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n        WHERE create_at AT TIME ZONE \'asia/ho_chi_minh\'\n              >= DATEADD(month, -3, DATE_TRUNC(\'month\', CURRENT_TIMESTAMP AT TIME ZONE \'asia/ho_chi_minh\'))\n    )\n    WHERE rn = 1\n)\nSELECT\n    id,\n    user_id,\n    loan_info.ApprovedAmount::bigint            AS approved_amount_vnd,\n    loan_info.LoanAmount::bigint                AS requested_amount_vnd,\n    loan_info.ApprovedTerm::int                 AS approved_term_months,\n    loan_info.ApprovedInterest::decimal(6,2)    AS approved_apr_pct,\n    loan_info.MonthlyRepaymentAmount::bigint    AS monthly_repayment_vnd,\n    loan_info.TotalInterestAmount::bigint       AS total_interest_vnd,\n    loan_info.InsuranceRegistered::boolean      AS has_insurance\nFROM latest_loan\nWHERE partner_code = \'TNEX\'\n  AND status = 1\nORDER BY approved_amount_vnd DESC;\n```\n\n**CAKE-only — arrears pulled from `partner_data.loan_detail` SUPER:**\n\n```sql\n-- partner_data.loan_detail exists ONLY for CAKE. For SHB/TNEX arrears, use root overdue_amount instead.\nSET enable_case_sensitive_super_attribute TO true;\n\nWITH latest_loan AS (\n    SELECT *\n    FROM (\n        SELECT\n            *,\n            ROW_NUMBER() OVER (PARTITION BY id ORDER BY update_at DESC) AS rn\n        FROM datawarehouse.cashloan_active_loans_mart\n    )\n    WHERE rn = 1\n)\nSELECT\n    id,\n    user_id,\n    partner_data.loan_detail.day_arrears::int                 AS days_past_due,\n    partner_data.loan_detail.principle_balance::bigint        AS principal_balance_vnd,\n    partner_data.loan_detail.interest_balance::bigint         AS interest_balance_vnd,\n    partner_data.loan_detail.penalty_principal_balance::bigint AS penalty_principal_vnd,\n    partner_data.loan_detail.loan_account_status::varchar     AS partner_loan_status\nFROM latest_loan\nWHERE partner_code = \'CAKE\'\n  AND status = 1\n  AND partner_data.loan_detail.day_arrears::int > 0\nORDER BY days_past_due DESC;\n```\n\n---\n\n## Gotchas summary\n\n1. **Append-only table** — dedupe on `id` ordered by **`update_at DESC`** (not `update_time`, not `sys_effective_date`) before any aggregation. See `SKILL.md`.\n2. **\"active_loans\" includes settled loans** — filter `status = 1` for the live book, `status = 2` for repaid. Don\'t assume every row is active.\n3. **Balance snapshot vs. disbursement cohort** — for current outstanding/overdue, drop the `create_at` window and filter `status = 1`. A 3-month `create_at` filter excludes older loans still outstanding.\n4. **`partner_data` has NO shared schema** — CAKE nests balances under `loan_detail.*`; SHB and TNEX carry none there. **For SHB/TNEX balances and arrears, always use root `outstanding_amount` / `overdue_amount`.** Don\'t write one `partner_data` path and expect it to work across partners.\n5. **`loan_info` / `partner_data` are SUPER, not varchar** — use path notation + `::type` casts, not `JSON_EXTRACT_PATH_TEXT`. Add `SET enable_case_sensitive_super_attribute TO true;` and quote mixed-case keys.\n6. **`loan_amount` (disbursed) ≠ `loan_info.LoanAmount` (requested)** — use the pair for approval-haircut analysis; don\'t conflate them.\n7. **`loan_term` is a bare month count string** (`\'9\'`, not `\'9M\'`) — cast with `loan_term::int`.\n8. **`ZaloPayScore` is `\"1\"` (placeholder) for some partners** (CAKE/TNEX) and a real score for others (SHB) — don\'t treat the placeholder as a real risk score.\n9. **`user_skey` is NULL in samples** — join on `user_id` (varchar), which is also the cross-domain key to BNPL tables.\n10. **Partner ask rule applies** — if a query touches `partner_code` and the user hasn\'t named a partner, ask first and offer \"broken out separately.\" Don\'t blend partners.\n\n---\n\n## Source samples\n\nGround-truth files this schema was derived from live in `references/cashloan-samples/` — load them only if you need to re-verify a SUPER sub-field\'s exact shape or casing:\n\n- `cake.csv`, `shb.csv`, `tnex.csv` — one real (anonymized) row per partner, full 19 columns including the raw `loan_info` / `partner_data` SUPER payloads.\n- `field_description.csv` — source-system field descriptions (note: uses source names like `zalopay_id` / `created_at`; the warehouse columns are `user_id` / `create_at` — this doc reflects the warehouse names).\n- `datawarehouse_cashloan_active_loans_mart.csv` — the warehouse column/type export (the 15 business columns; the 4 standard mart columns are added in the live table).\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('d657da13-273e-46ad-aac4-e398d3ab7783','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/schema-shared.md','# Shared Dimensions\n\nCross-domain reference tables: users, partners, status enums, date utilities. Loaded when a query joins across BNPL / Cash Loan / Payment domains, or needs canonical enum values.\n\n> **Status:** Skeleton — to be filled in with actual table names and columns.\n\n## Tables\n\n### `<users_table>`\nTBD — paste schema.\n\n### `<partners_table>`\nTBD — paste schema.\n\n## Status enums\n\n### Transaction status\nTBD — list canonical values (e.g., `SUCCESS`, `FAILED`, `PENDING`, `REFUNDED`).\n\n### Loan/BNPL status\nTBD — list canonical values (e.g., `ACTIVE`, `PAID_OFF`, `DELINQUENT`, `WRITTEN_OFF`).\n\n## Partner codes\n\n| Code | Partner | Domain(s) |\n|------|---------|-----------|\n| CIMB | CIMB Bank | BNPL, Cash Loan |\n| CAKE | CAKE by VPBank | BNPL, Cash Loan |\n| TNEX | TNEX | Cash Loan |\n| SHB  | SHB | Cash Loan |\n| LFVN | Lotte Finance Vietnam | Cash Loan |\n| VietCredit | VietCredit | Cash Loan |\n| VPB | VPBank | Cash Loan |\n\n> Confirm this list and add any missing partners.\n\n## Common filters\n\n- **Exclude test users:** TBD — what\'s the test user filter? (e.g., `user_id NOT IN (SELECT user_id FROM test_users)` or a flag column?)\n- **Exclude internal staff:** TBD.\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
INSERT INTO `skill_files` VALUES ('f8688b0b-5820-47c5-8799-ca5cd8689ef8','00000000-0000-0000-0000-000000000001','c157d419-2688-4216-ad4d-39721373ec68','references/cashloan-samples/shb.csv','mart_skey,id,loan_application_id,user_skey,user_id,partner_code,outstanding_amount,overdue_amount,partner_contract_number,loan_amount,loan_term,loan_info,partner_data,create_at,update_at,sys_effective_date,sys_create_date,settle_at,status\n18703656,856519,20260601-7b4c6622-272e-4ca1-a739-e86260eea40a,,200129000038888,SHB,10000000,0,542606013053394,10000000,9,\"{\"\"LoanFee\"\":0,\"\"Partner\"\":\"\"SHB\"\",\"\"Interest\"\":55,\"\"LoanTerm\"\":\"\"9\"\",\"\"ScoreBand\"\":\"\"02. High\"\",\"\"FinalCheck\"\":{\"\"Score\"\":0,\"\"UserIP\"\":\"\"\"\",\"\"DeviceID\"\":\"\"\"\",\"\"DeviceOs\"\":\"\"\"\",\"\"Platform\"\":\"\"\"\",\"\"ScoreBand\"\":\"\"\"\",\"\"UserAgent\"\":\"\"\"\",\"\"AppVersion\"\":\"\"\"\",\"\"ScoreMonth\"\":\"\"\"\",\"\"DeviceModel\"\":\"\"\"\",\"\"UserSegment\"\":\"\"\"\",\"\"ScoreVersion\"\":\"\"\"\",\"\"UserSegments\"\":null},\"\"FirstCheck\"\":{\"\"Score\"\":922,\"\"UserIP\"\":\"\"14.170.149.181\"\",\"\"DeviceID\"\":\"\"670CC343-0077-42AB-AB5B-09CACBA21AC5\"\",\"\"DeviceOs\"\":\"\"ios\"\",\"\"Platform\"\":\"\"zpa\"\",\"\"ScoreBand\"\":\"\"02. High\"\",\"\"UserAgent\"\":\"\"Mozilla/5.0 (iPhone; CPU iPhone OS 26_0_1 like Mac OS X) AppleWebKit/8622.1.22.10.11, Copyright 2003-2025 Apple Inc. (KHTML, like Gecko) Mobile/23A354 ZaloPayClient/11.5.1 ZaloPayWebClient/11.5.1 OS/26.0.1 Platform/ios Secured/true\"\",\"\"AppVersion\"\":\"\"11.5.1\"\",\"\"ScoreMonth\"\":\"\"2026-04\"\",\"\"DeviceModel\"\":\"\"iPhone17,2\"\",\"\"UserSegment\"\":\"\"zalopay_bau\"\",\"\"ScoreVersion\"\":\"\"pre_loan_v3_2_5\"\",\"\"UserSegments\"\":[\"\"zalopay_bau\"\"]},\"\"LoanAmount\"\":10000000,\"\"ConsentData\"\":{\"\"sso\"\":true,\"\"consent_content\"\":\"\"\"\"},\"\"ProductCode\"\":\"\"ZALOPAY_MASS\"\",\"\"ProductLine\"\":0,\"\"TotalAmount\"\":12428224,\"\"ApprovedTerm\"\":\"\"9\"\",\"\"InsuranceFee\"\":0,\"\"StartPayDate\"\":\"\"2026-07-01\"\",\"\"ZaloPayScore\"\":\"\"922\"\",\"\"CollectionFee\"\":108000,\"\"ApprovedAmount\"\":10000000,\"\"MonthlyInterest\"\":\"\"4.58\"\",\"\"ApprovedInterest\"\":55,\"\"InsurancePartner\"\":null,\"\"InsuranceRegistered\"\":false,\"\"TotalInterestAmount\"\":2428224,\"\"ApprovedInsuranceFee\"\":0,\"\"MonthlyRepaymentAmount\"\":1380914}\",\"{\"\"submit_full_lead\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"time\"\":\"\"2026-06-01T06:54:06.25927211+07:00\"\"},\"\"StepCode\"\":\"\"DONE\"\",\"\"ResponseCode\"\":\"\"DISBURSEMENT\"\",\"\"SubmittedTime\"\":1780271646259,\"\"ApprovedTerm\"\":\"\"9\"\",\"\"DocumentFileDatas\"\":\"\"[{\\\"\"documentId\\\"\":\\\"\"37a60a52-aa67-442a-965e-f9f2d3e8afa2\\\"\",\\\"\"documentCode\\\"\":\\\"\"IdentityCardFront\\\"\",\\\"\"documentName\\\"\":\\\"\"Mặt trước CMND/CCCD\\\"\",\\\"\"message\\\"\":\\\"\"Thành công\\\"\",\\\"\"status\\\"\":\\\"\"200\\\"\"},{\\\"\"documentId\\\"\":\\\"\"564eec4d-8685-4f1a-ac72-8af1e8373b3e\\\"\",\\\"\"documentCode\\\"\":\\\"\"IdentityCardBack\\\"\",\\\"\"documentName\\\"\":\\\"\"Mặt sau CMND/CCCD\\\"\",\\\"\"message\\\"\":\\\"\"Thành công\\\"\",\\\"\"status\\\"\":\\\"\"200\\\"\"},{\\\"\"documentId\\\"\":\\\"\"6d1e7790-c896-4525-8e57-bcc5730ebc8b\\\"\",\\\"\"documentCode\\\"\":\\\"\"CustomerPhoto\\\"\",\\\"\"documentName\\\"\":\\\"\"Ảnh khách hàng\\\"\",\\\"\"message\\\"\":\\\"\"Thành công\\\"\",\\\"\"status\\\"\":\\\"\"200\\\"\"}]\"\",\"\"DisbursementTime\"\":0,\"\"BillCode\"\":\"\"SHBFINANCE-260601064651-153941888-098158\"\",\"\"upload_images\"\":{\"\"code\"\":\"\"\"\",\"\"error\"\":\"\"\"\",\"\"time\"\":\"\"2026-06-01T06:54:05.273978139+07:00\"\"},\"\"TransactionId\"\":\"\"C58D4A4AC55E91ED4D63F7E2580C07F9\"\",\"\"AppCode\"\":\"\"DG96F2C2606018899625\"\",\"\"LoanAmount\"\":10000000,\"\"ApprovedAmount\"\":10000000,\"\"ApprovalTime\"\":1780272307537,\"\"BypassVerifyOTP\"\":false,\"\"retrigger_workflow_info\"\":{},\"\"LeadId\"\":\"\"20260601-7b4c6622-272e-4ca1-a739-e86260eea40a\"\",\"\"create_app_code\"\":{}}\",2026-06-01T00:06:04Z,2026-06-01T00:06:04Z,2026-06-01T00:06:04Z,2026-06-01T00:08:11Z,,1\n','2026-06-17 05:36:27','2026-06-17 05:36:27');
