  `id` char(36) NOT NULL,
  `workspace_id` char(36) NOT NULL,
  `name` varchar(255) NOT NULL,
  `prompt` mediumtext NOT NULL,
  `session_prefix` varchar(128) NOT NULL DEFAULT 'routine',
  `enabled` tinyint(1) NOT NULL DEFAULT '1',
  `schedule_cron` varchar(128) DEFAULT NULL,
  `schedule_tz` varchar(64) NOT NULL DEFAULT 'Asia/Ho_Chi_Minh',
  `temporal_schedule_id` varchar(255) DEFAULT NULL,
  `fire_token_hash` char(64) DEFAULT NULL,
  `created_by` varchar(255) DEFAULT NULL,
  `created_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `updated_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  `deleted_at` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  UNIQUE KEY `uq_routines_fire_token` (`fire_token_hash`),
  KEY `idx_routines_ws` (`workspace_id`),
  KEY `idx_routines_deleted` (`deleted_at`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
