INSERT INTO `memory_docs` VALUES ('0c8d63bd-158c-47a0-a3b8-c4b57d7e9955','00000000-0000-0000-0000-000000000001','global',NULL,'memory/preferences.md','User preference: Khi lấy dữ liệu, mặc định sử dụng skill chat-json-render-output để visualize dữ liệu cho phù hợp, trừ khi có yêu cầu cụ thể lấy dữ liệu thô (không cần visualize).',NULL,'2026-06-16 21:18:33','2026-06-16 21:18:33');
INSERT INTO `memory_docs` VALUES ('5956ea8e-cb30-431a-ab6e-77a1b5a6f311','00000000-0000-0000-0000-000000000001','global',NULL,'memory/jira_link_formatting_preference.md','Rule: When generating JIRA comments with links, use short, clear titles and avoid special characters in the title to ensure the link is clickable. Example: [Short Title|URL] instead of [Long Title with [Special] Characters|URL].',NULL,'2026-03-17 02:53:21','2026-03-17 02:53:21');
INSERT INTO `memory_docs` VALUES ('fc38b64e-bd5d-44f1-8f9f-5e7c8a4e3e44','00000000-0000-0000-0000-000000000001','global',NULL,'memory/error_code_interpretations.md','\n### Error Code: -32 (valid_rule_failed) with RPC InvalidArgument from Partner\n\nWhen a loan application has:\n*   **Status: -2** (Cancelled/Rejected)\n*   **Code: -32 (valid_rule_failed)**\n*   **Description (from logs):** `rpc error: code = InvalidArgument desc = unknown error` from a partner (e.g., TNEX)\n\nThis indicates that the issue is likely due to **ZaloPay sending an API request with invalid parameters to the partner\'s system**, preventing the partner from processing the request. This is an API integration level error, not a business rule rejection after successful processing by the partner.\n',NULL,'2026-02-28 00:55:19','2026-02-28 00:55:19');
/*!40000 ALTER TABLE `memory_docs` ENABLE KEYS */;
UNLOCK TABLES;

--
-- Table structure for table `routine_runs`
--

DROP TABLE IF EXISTS `routine_runs`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `routine_runs` (
  `id` char(36) NOT NULL,
  `routine_id` char(36) NOT NULL,
  `workspace_id` char(36) NOT NULL,
  `trigger_type` enum('schedule','api','manual') NOT NULL,
  `status` enum('running','success','failed') NOT NULL DEFAULT 'running',
  `session_key` varchar(255) DEFAULT NULL,
  `workflow_id` varchar(255) DEFAULT NULL,
  `temporal_run_id` varchar(255) DEFAULT NULL,
  `input_text` mediumtext,
  `output_preview` mediumtext,
  `error` text,
  `input_tokens` int NOT NULL DEFAULT '0',
  `output_tokens` int NOT NULL DEFAULT '0',
  `iterations` int NOT NULL DEFAULT '0',
  `started_at` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `finished_at` timestamp NULL DEFAULT NULL,
  `duration_ms` bigint NOT NULL DEFAULT '0',
  PRIMARY KEY (`id`),
  KEY `idx_runs_routine` (`workspace_id`,`routine_id`,`started_at`),
  KEY `idx_runs_workflow` (`workflow_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;
