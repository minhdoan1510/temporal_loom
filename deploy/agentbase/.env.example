# Copy to deploy/agentbase/.env and fill in. Used by scripts/deploy-agentbase.sh.
# Never commit the filled-in .env.

# --- GreenNode Container Registry (vCR) ---
# Robot/account that can push to the org registry. VCR_REPO is the repo/project
# name shown by `cr.sh repo get` in the AgentBase console (image becomes
# vcr.vngcloud.vn/<VCR_REPO>/lending-claw:<tag>).
VCR_REPO=
VCR_USERNAME=
VCR_PASSWORD=

# --- AgentBase Agent Runtime API ---
# Bearer token for https://agentbase.api.vngcloud.vn (from the AgentBase console).
AGENTBASE_TOKEN=
# Optional overrides:
# IMAGE_TAG=                 # default: short git sha
# RUNTIME_NAME=lending-claw  # name of the agent runtime
# AGENTBASE_FLAVOR=2x4-general  # MUST be a valid flavor id; all-in-one needs RAM

# --- App secrets (injected as runtime env vars, consumed by config template) ---
# Use a URL-safe MySQL password (it is embedded in a DSN / migrate URL).
MYSQL_PASSWORD=
JWT_SECRET=
ENCRYPTION_KEY=
MCP_AUTH_TOKEN=
LLM_API_KEY=
JIRA_PERSONAL_TOKEN=
OPENSEARCH_PASSWORD=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
CONFLUENCE_API_KEY=
