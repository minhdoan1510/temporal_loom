# Standalone MCP server config template (separate AgentBase runtime).
#
# Rendered at container start by `deploy/agentbase/mcp-entrypoint.sh` via `envsubst` into
# /etc/mcp/config.yaml. ${VARS} are filled from environment variables injected by
# AgentBase (set in the deploy-mcp job -> environmentVariables).
#
# Only the sections the MCP binary reads are present (see mcp/internal/config).
# No MySQL / Qdrant / LLM are needed by the MCP server.

# Listen on 8080: AgentBase routes external traffic and runs its health check
# against port 8080 only. Serving on any other port makes the probe fail and the
# platform SIGTERMs the container.
mcp_server:
  host: "0.0.0.0"
  port: 8080
  auth_token: "${MCP_AUTH_TOKEN}"

telemetry:
  service_name: "lending-claw-mcp"
  otlp_endpoint: ""

# Required by the datawarehouse MCP server (/mcp/datawarehouse). Without base_url
# + api_key, dwserver.New() returns nil and the endpoint is never mounted -> 404.
llm:
  provider: "litellm"
  model: "gemini/gemini-3.1-pro-preview"
  base_url: "https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1"
  api_key: "${LLM_API_KEY}"

datawarehouse:
  mock: true
  model: ""

# Required by the mail MCP server (/mcp/mail). Without resend_api_key,
# mailserver.New() returns nil and the endpoint is never mounted -> 404.
mail:
  resend_api_key: "${MAIL_RESEND_API_KEY}"
  from_email: "admin@mixai.app"

jira:
  url: "https://jira.zalopay.vn"
  personal_token: "${JIRA_PERSONAL_TOKEN}"

opensearch:
  host: "10.60.45.80"
  port: 8200
  user: "fin_dev"
  password: "${OPENSEARCH_PASSWORD}"
  index: "zlp-logs-fin-cash-loan-dev"

onboarding:
  grpc_address: "devgrpc-fin-lending.zalopay.vn:443"
  grpc_secure: true
  client_id: "cashloan-onboard"
  client_key: "abc@123"
